---
import "../styles/global.css";

const { title = "NikolayP2" } = Astro.props;

import avatarSrc from "../images/avatar.jpg";
import videoCtaSrc from "../images/video-cta.png";
import { profileLinks } from "../config/links";

const header = {
  name: "Nikolai Posvezhnyi",
  avatarSrc: avatarSrc.src,
  ...profileLinks,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="header">
      <div class="nav">
        <div class="brand" aria-label="Author">
          <a class="brandLink" href="/">
            <img
              class="avatar"
              src={header.avatarSrc}
              alt={`${header.name} avatar`}
            />
            <span class="brandName">{header.name}</span>
          </a>
        </div>

        <nav class="navLinks desktop-only" aria-label="External links">
          <a href={header.cvUrl} target="_blank" rel="noreferrer noopener">CV</a>
          <a href={header.linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a href={header.aboutUrl}>About</a>
          <a href={`mailto:${header.email}`}>Email</a>
          <a href={header.telegramUrl} target="_blank" rel="noreferrer noopener">Telegram</a>
        </nav>

        <nav class="navLinks mobile-only" aria-label="External links">
          <button
            type="button"
            id="contacts-menu-open"
            class="contactsMenuOpen"
            aria-expanded="false"
            aria-controls="contacts-menu"
            aria-haspopup="dialog"
          >
            <span class="navLinksLabel">Contacts</span>
            <span class="icon-plus" aria-hidden="true"></span>
          </button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="footer">
      <div class="container footerInner">
        <div class="footerCopy">© 2026 Nikolai Posvezhnyi + AI = ❤</div>
        <div class="footerLinks desktop-only">
          <div class="footerLink">
            <a href={`mailto:${profileLinks.email}`}>{profileLinks.email}</a>
          </div>
          <div class="footerLink">
            <span class="footerLinkLabel">tg:</span>
            <a href={profileLinks.telegramUrl} target="_blank" rel="noreferrer noopener">
              {profileLinks.telegramHandle}
            </a>
          </div>
        </div>
      </div>
    </footer>

    <div class="videoCta" id="video-cta-widget">
      <div class="videoCtaInner">
        <button
          type="button"
          class="videoCtaClose"
          id="video-cta-close"
          aria-label="Close intro"
        >
          <span class="icon-close"></span>
        </button>
        <a
          class="videoCtaCircle"
          href={profileLinks.introVideoUrl}
          target="_blank"
          rel="noreferrer noopener"
          aria-label="Watch a Quick Intro"
        >
          <img
            class="videoCtaPhoto"
            src={videoCtaSrc.src}
            alt=""
            width="240"
            height="240"
            loading="lazy"
          />
          <span class="videoCtaPlay icon-play"></span>
        </a>
      </div>
    </div>

    <div
      id="contacts-menu"
      class="contactsFullscreen"
      role="dialog"
      aria-modal="true"
      aria-label="Contacts"
      hidden
    >
      <button
        type="button"
        id="contacts-menu-close"
        class="contactsFullscreenClose"
        aria-label="Close menu"
      >
        <span class="contactsFullscreenCloseLabel">Close</span>
        <span class="icon-minus"></span>
      </button>
      <nav class="contactsFullscreenNav" aria-label="Contact links">
        <a href={header.cvUrl} target="_blank" rel="noreferrer noopener">CV</a>
        <a href={header.linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a href={header.aboutUrl}>About</a>
        <a href={`mailto:${header.email}`}>Email</a>
        <a href={header.telegramUrl} target="_blank" rel="noreferrer noopener">Telegram</a>
      </nav>
    </div>

    <script is:inline>
      (function () {
        var openBtn = document.getElementById("contacts-menu-open");
        var menu = document.getElementById("contacts-menu");
        var closeBtn = document.getElementById("contacts-menu-close");
        if (!openBtn || !menu) return;

        function openMenu() {
          menu.hidden = false;
          menu.setAttribute("aria-hidden", "false");
          openBtn.setAttribute("aria-expanded", "true");
          document.body.style.overflow = "hidden";
          if (closeBtn) closeBtn.focus();
        }

        function closeMenu() {
          menu.hidden = true;
          menu.setAttribute("aria-hidden", "true");
          openBtn.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
          openBtn.focus();
        }

        openBtn.addEventListener("click", openMenu);
        if (closeBtn) closeBtn.addEventListener("click", closeMenu);

        menu.addEventListener("click", function (e) {
          if (e.target === menu) closeMenu();
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && !menu.hidden) {
            e.preventDefault();
            closeMenu();
          }
        });

        var navLinks = menu.querySelectorAll(".contactsFullscreenNav a");
        for (var i = 0; i < navLinks.length; i++) {
          navLinks[i].addEventListener("click", closeMenu);
        }
      })();
    </script>

    <script is:inline>
      (function () {
        var widget = document.getElementById("video-cta-widget");
        var closeBtn = document.getElementById("video-cta-close");
        if (!widget || !closeBtn) return;
        closeBtn.addEventListener("click", function (e) {
          e.preventDefault();
          e.stopPropagation();
          widget.hidden = true;
        });
      })();
    </script>

    <style>
      .header {
        padding: 1.388vw 2.083vw 1.388vw 1.388vw;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brandLink {
        display: flex;
        align-items: center;
        gap: 0.6944vw;
      }

      .avatar {
        border-radius: 999px;
        display: block;
        object-fit: cover;
        width: 2.778vw;
        height: 2.778vw;
      }

      .navLinks {
        display: flex;
        gap: 1.388vw;
      }
      .navLinks.mobile-only {
        display: none;
      }

      .navLinks button,
      .contactsMenuOpen {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        margin: 0;
      }

      .contactsFullscreen {
        position: fixed;
        inset: 0;
        z-index: 10000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.8);
        -webkit-backdrop-filter: blur(10px);
        backdrop-filter: blur(10px);
        padding: 0;
        color: var(--color-bg, #ffffff);
      }

      .contactsFullscreen[hidden] {
        display: none;
      }

      .contactsFullscreenClose {
        position: absolute;
        top: 4vw;
        right: 4vw;
        border: none;
        background: transparent;
        font-size: 4vw;
        line-height: 5.333vw;
        cursor: pointer;
        color: var(--color-bg, #000);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        gap: 0.5333vw;
      }

      .contactsFullscreenNav {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 5.333vw;
      }

      .contactsFullscreenNav a {
        font-size: 4.8vw;
        line-height: 5.333vw;
        font-weight: 500;
        color: var(--color-bg, #ffffff);
        text-decoration: none;
      }

      .contactsFullscreenNav a:hover {
        color: var(--color-primary, #ff4001);
        text-decoration: none;
      }

      .videoCta {
        position: fixed;
        z-index: 9000;
        bottom: 1.3889vw;
        right: 1.3889vw;
        width: 12.5vw;
        pointer-events: none;
      }

      .videoCtaInner {
        position: relative;
        pointer-events: auto;
      }

      .videoCta[hidden] {
        display: none;
      }

      .videoCtaClose {
        position: absolute;
        top: 0;
        right: 0;
        z-index: 2;
        border: none;
        padding: 0;
        margin: 0;
        background: transparent;
        color: var(--color-gray);
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .videoCtaClose:hover {
        color: var(--color-primary);
      }

      .videoCtaCircle {
        position: relative;
        display: block;
        aspect-ratio: 1;
        border-radius: 50%;
        overflow: hidden;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
        text-decoration: none;
      }

      .videoCtaPhoto {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .videoCtaPlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #ffffff;
        pointer-events: none;
        filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.35));
      }

      .videoCtaPlay svg {
        width: min(26%, 52px);
        height: auto;
      }

      .videoCtaArc {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100%;
        height: 52%;
        pointer-events: none;
      }

      .videoCtaArcText {
        filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.45));
      }

      nav {
        display: flex;
      }

      .footerInner {
        border-top: 1px solid var(--color-gray);
        color: rgba(0, 0, 0, 0.3);
        padding: 2.0833vw 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.041vw;
      }

      .footerCopy {
        white-space: nowrap;
      }

      .footerLinks {
        display: flex;
        gap: 1.736vw;
      }

      .footerLink a {
        color: var(--color-fg);
      }

      @media (max-width: 600px) {
        .navLinks.desktop-only {
          display: none;
        }
        .navLinks.mobile-only {
          display: block;
        }
        .navLinks button,
        .contactsMenuOpen {
          display: flex;
          font-size: 4vw;
          line-height: 1.25;
          gap: 1.333vw;
        }
        .navLinks .icon-plus {
          width: 3.73vw;
          height: 3.73vw;
          margin-top: 0.633vw;
          vertical-align: top;
        }
        .header {
          padding: 4vw;
        }
        .brandLink {
          gap: 1.3333vw;
        }

        .avatar {
          width: 5.3333vw;
          height: 5.3333vw;
        }

        .footer {
          flex-direction: column;
          align-items: flex-start;
          padding: 0 4vw;
        }
        .footerInner {
          padding: 6.6667vw 0;
        }
        .footerLinks {
          display: none;
        }
      }
    </style>
  </body>
</html>

