---
import "../styles/global.css";
import "../styles/icons.css";

const { title = "NikolayP2", page: pageOverride } = Astro.props;

/** Maps URL to `home` | `about` | `case` for the `<html>` class (override with `page` prop). */
function pageClassFromPathname(pathname: string): string {
  const normalized = pathname.replace(/\/+$/, "") || "/";
  if (normalized === "/") return "home";
  if (normalized === "/about" || normalized.startsWith("/about/")) return "about";
  if (normalized === "/cases" || normalized.startsWith("/cases/")) return "case";
  return "";
}

const pageClass = pageOverride ?? pageClassFromPathname(Astro.url.pathname);

import avatarSrc from "../images/avatar.jpg";
import videoCtaSrc from "../images/video-cta.png";
import videoCtaMobileSrc from "../images/video-cta-mobile.png";
import faviconIco from "../images/favicon/favicon.ico?url";
import favicon16 from "../images/favicon/favicon-16x16.png?url";
import favicon32 from "../images/favicon/favicon-32x32.png?url";
import appleTouchIcon from "../images/favicon/apple-touch-icon.png?url";
import androidChrome96 from "../images/favicon/android-chrome-96x96.png?url";
import androidChrome192 from "../images/favicon/android-chrome-192x192.png?url";
import androidChrome256 from "../images/favicon/android-chrome-256x256.png?url";
import safariPinnedTab from "../images/favicon/safari-pinned-tab.svg?url";
import mstile150 from "../images/favicon/mstile-150x150.png?url";
import { profileLinks } from "../config/links";
import { getIntroVideoMedia } from "../config/introVideo";

const header = {
  name: "Nikolai Posvezhnyi",
  avatarSrc: avatarSrc.src,
  ...profileLinks,
};

const introMedia = getIntroVideoMedia(profileLinks.introVideoUrl);

const siteManifest = {
  name: header.name,
  short_name: "Portfolio",
  icons: [
    { src: androidChrome96, sizes: "96x96", type: "image/png" },
    { src: androidChrome192, sizes: "192x192", type: "image/png" },
    { src: androidChrome256, sizes: "256x256", type: "image/png" },
  ],
  theme_color: "#ffffff",
  background_color: "#ffffff",
  display: "standalone" as const,
};
const siteManifestHref = `data:application/manifest+json;charset=utf-8,${encodeURIComponent(
  JSON.stringify(siteManifest)
)}`;
---

<!doctype html>
<html lang="en" class:list={[pageClass].filter(Boolean)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <link rel="icon" href={faviconIco} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />
    <link rel="manifest" href={siteManifestHref} />
    <link rel="mask-icon" href={safariPinnedTab} color="#000000" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta name="msapplication-TileImage" content={mstile150} />
  </head>
  <body>
    <header class="header">
      <div class="headerFx" aria-hidden="true">
        <div class="headerGradientBlur">
          <div></div>
          <div></div>
          <div></div>
          <div></div>
          <div></div>
          <div></div>
        </div>
        <div class="headerFxTint"></div>
      </div>
      <div class="nav">
        <div class="brand" aria-label="Author">
          <a class="brandLink" href="/">
            <img
              class="avatar"
              src={header.avatarSrc}
              alt={`${header.name} avatar`}
            />
            <span class="brandName">{header.name}</span>
          </a>
          <button
            type="button"
            class="brandLinkButton"
            id="brand-intro-open"
            aria-haspopup="dialog"
            aria-controls="video-intro-modal"
            aria-label="Watch a Quick Intro"
          >
            <span class="brandName">Intro</span>
            <span class="brandVideo">
              <span class="icon-play-small"></span>
              <span class="brandVideoTime desktop-only">1:04</span>
            </span>
          </button>
        </div>

        <nav class="navLinks desktop-only" aria-label="External links">
          <a href={header.cvUrl} target="_blank" rel="noreferrer noopener">CV</a>
          <a href={header.linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a href={`mailto:${header.email}`}>Email</a>
          <a href={header.telegramUrl} target="_blank" rel="noreferrer noopener">Telegram</a>
        </nav>

        <nav class="navLinks mobile-only" aria-label="External links">
          <button
            type="button"
            id="contacts-menu-open"
            class="contactsMenuOpen"
            aria-expanded="false"
            aria-controls="contacts-menu"
            aria-haspopup="dialog"
          >
            <span class="navLinksLabel">Contacts</span>
            <span class="icon-plus" aria-hidden="true"></span>
          </button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <section class="homeBottom" aria-label="Extra shots and contact call to action">
      <div class="hero __bottom">
        <div class="heroInner">
          <h3 class="heroTitle">Building something bold?</h3>
          <p class="heroAccent">Let&apos;s design it right.</p>
          <div class="heroActions">
            <a class="primaryButton heroEmail" href={`mailto:${profileLinks.email}`}>
              Email Me
            </a>
            <a
              class="primaryButton heroTelegram"
              href={profileLinks.telegramUrl}
              target="_blank"
              rel="noreferrer noopener"
              aria-label="Telegram"
            >
              <span class="icon-telegram" aria-hidden="true"></span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <footer class="footer">
      <div class="container footerInner">
        <div class="footerCopy">© 2026 Nikolai Posvezhnyi + AI = ❤</div>
        <div class="footerLinks desktop-only">
          <div class="footerLink">
            <a href={`mailto:${profileLinks.email}`}>{profileLinks.email}</a>
          </div>
          <div class="footerLink">
            <span class="footerLinkLabel">tg:</span>
            <a href={profileLinks.telegramUrl} target="_blank" rel="noreferrer noopener">
              {profileLinks.telegramHandle}
            </a>
          </div>
        </div>
      </div>
    </footer>

    <div class="videoCta" id="video-cta-widget">
      <div class="videoCtaInner">
        <button
          type="button"
          class="videoCtaClose"
          id="video-cta-close"
          aria-label="Close intro"
        >
          <span class="icon-close"></span>
        </button>
        <button
          type="button"
          class="videoCtaCircle"
          id="video-cta-open"
          aria-haspopup="dialog"
          aria-controls="video-intro-modal"
          aria-label="Watch a Quick Intro"
        >
          <img
            class="videoCtaPhoto desktop-only"
            src={videoCtaSrc.src}
            alt=""
            loading="lazy"
          />
          <img
            class="videoCtaPhoto mobile-only"
            src={videoCtaMobileSrc.src}
            alt=""
            loading="lazy"
          />
          <span class="videoCtaPlay icon-play"></span>
        </button>
      </div>
    </div>

    <div
      id="video-intro-modal"
      class="videoIntroModal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="video-intro-title"
      hidden
    >
      <button
        type="button"
        id="video-intro-close"
        class="videoIntroModalClose"
        aria-label="Close video"
      >
        <span class="icon-close-circle"></span>
      </button>
      <div class="videoIntroModalInner">
        <h2 id="video-intro-title" class="videoIntroModalSrOnly">Intro video</h2>
        {introMedia.kind === "iframe" && (
          <div class="videoIntroModalRatio">
            <iframe
              id="video-intro-iframe"
              class="videoIntroModalFrame"
              title="Intro video"
              data-embed-base={introMedia.src}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        )}
        {introMedia.kind === "video" && (
          <video
            id="video-intro-html5"
            class="videoIntroModalVideo"
            controls
            playsinline
            preload="none"
            data-src={introMedia.src}
          />
        )}
        {introMedia.kind === "link" && (
          <div class="videoIntroModalFallback">
            <p class="videoIntroModalFallbackText">
              Set a YouTube, Vimeo, or direct video URL in <code>introVideoUrl</code>.
            </p>
            <a
              class="primaryButton videoIntroModalFallbackBtn"
              href={introMedia.href}
              target="_blank"
              rel="noreferrer noopener"
            >
              Open link
            </a>
          </div>
        )}
      </div>
    </div>

    <div
      id="contacts-menu"
      class="contactsFullscreen"
      role="dialog"
      aria-modal="true"
      aria-label="Contacts"
      hidden
    >
      <button
        type="button"
        id="contacts-menu-close"
        class="contactsFullscreenClose"
        aria-label="Close menu"
      >
        <span class="contactsFullscreenCloseLabel">Close</span>
        <span class="icon-minus"></span>
      </button>
      <nav class="contactsFullscreenNav" aria-label="Contact links">
        <a href={header.cvUrl} target="_blank" rel="noreferrer noopener">CV</a>
        <a href={header.linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
        <a href={`mailto:${header.email}`}>Email</a>
        <a href={header.telegramUrl} target="_blank" rel="noreferrer noopener">Telegram</a>
      </nav>
    </div>

    <script is:inline>
      (function () {
        var openBtn = document.getElementById("contacts-menu-open");
        var menu = document.getElementById("contacts-menu");
        var closeBtn = document.getElementById("contacts-menu-close");
        if (!openBtn || !menu) return;

        function openMenu() {
          menu.hidden = false;
          menu.setAttribute("aria-hidden", "false");
          openBtn.setAttribute("aria-expanded", "true");
          document.body.style.overflow = "hidden";
          if (closeBtn) closeBtn.focus();
        }

        function closeMenu() {
          menu.hidden = true;
          menu.setAttribute("aria-hidden", "true");
          openBtn.setAttribute("aria-expanded", "false");
          document.body.style.overflow = "";
          openBtn.focus();
        }

        openBtn.addEventListener("click", openMenu);
        if (closeBtn) closeBtn.addEventListener("click", closeMenu);

        menu.addEventListener("click", function (e) {
          if (e.target === menu) closeMenu();
        });

        document.addEventListener("keydown", function (e) {
          if (e.key === "Escape" && !menu.hidden) {
            e.preventDefault();
            closeMenu();
          }
        });

        var navLinks = menu.querySelectorAll(".contactsFullscreenNav a");
        for (var i = 0; i < navLinks.length; i++) {
          navLinks[i].addEventListener("click", closeMenu);
        }
      })();
    </script>

    <script is:inline>
      (function () {
        var widget = document.getElementById("video-cta-widget");
        var widgetClose = document.getElementById("video-cta-close");
        var openBtn = document.getElementById("video-cta-open");
        var brandIntroBtn = document.getElementById("brand-intro-open");
        var modal = document.getElementById("video-intro-modal");
        var modalClose = document.getElementById("video-intro-close");
        var iframe = document.getElementById("video-intro-iframe");
        var htmlVideo = document.getElementById("video-intro-html5");
        var lastIntroOpener = null;

        if (widget && widgetClose) {
          widgetClose.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            widget.hidden = true;
          });
        }

        function openVideoModal(e) {
          if (e && e.currentTarget) lastIntroOpener = e.currentTarget;
          if (!modal) return;
          modal.hidden = false;
          modal.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
          if (iframe && iframe.dataset.embedBase) {
            var base = iframe.dataset.embedBase;
            var sep = base.indexOf("?") >= 0 ? "&" : "?";
            iframe.src = base + sep + "autoplay=1";
          }
          if (htmlVideo && htmlVideo.dataset.src) {
            if (!htmlVideo.getAttribute("src")) {
              htmlVideo.src = htmlVideo.dataset.src;
            }
            try {
              htmlVideo.play();
            } catch (err) {}
          }
          if (modalClose) modalClose.focus();
        }

        function closeVideoModal() {
          if (!modal) return;
          modal.hidden = true;
          modal.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
          if (iframe) iframe.src = "";
          if (htmlVideo) {
            htmlVideo.pause();
            htmlVideo.removeAttribute("src");
            try {
              htmlVideo.load();
            } catch (err) {}
          }
          if (lastIntroOpener && document.body.contains(lastIntroOpener)) {
            try {
              lastIntroOpener.focus();
            } catch (err2) {}
          } else if (openBtn) openBtn.focus();
          lastIntroOpener = null;
        }

        if (openBtn) openBtn.addEventListener("click", openVideoModal);
        if (brandIntroBtn) brandIntroBtn.addEventListener("click", openVideoModal);
        if (modalClose) modalClose.addEventListener("click", closeVideoModal);
        if (modal) {
          modal.addEventListener("click", function (e) {
            if (e.target === modal) closeVideoModal();
          });
        }

        document.addEventListener(
          "keydown",
          function (e) {
            if (e.key !== "Escape") return;
            if (!modal || modal.hidden) return;
            e.preventDefault();
            e.stopImmediatePropagation();
            closeVideoModal();
          },
          true
        );
      })();
    </script>

    <style>
      .header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 1.388vw 2.083vw 2.083vw 1.388vw;
        background: transparent;
        isolation: isolate;
      }

      /*
        Stacked backdrop blurs + band masks (gradient-blur technique).
        Original snippet grows blur toward bottom; header mirrors bands so max blur is at top (Figma).
        Blur steps scaled × (20/64) so peak ≈ 20px like design.
      */
      .headerFx {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }

      .headerGradientBlur {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }

      .headerGradientBlur::before,
      .headerGradientBlur::after,
      .headerGradientBlur > div {
        position: absolute;
        inset: 0;
        transform: translateZ(0);
        pointer-events: none;
        -webkit-mask-size: 100% 100%;
        mask-size: 100% 100%;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
      }

      /* Soft feathered masks (ease in/out) instead of hard 0→1 bands */
      .headerGradientBlur::before {
        content: "";
        z-index: 1;
        -webkit-backdrop-filter: blur(0.5px) saturate(1.35);
        backdrop-filter: blur(0.5px) saturate(1.35);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 56%,
          rgba(0, 0, 0, 0.35) 66%,
          rgba(0, 0, 0, 0.85) 76%,
          rgba(0, 0, 0, 1) 81%,
          rgba(0, 0, 0, 0.85) 86%,
          rgba(0, 0, 0, 0.35) 93%,
          rgba(0, 0, 0, 0) 100%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 56%,
          rgba(0, 0, 0, 0.35) 66%,
          rgba(0, 0, 0, 0.85) 76%,
          rgba(0, 0, 0, 1) 81%,
          rgba(0, 0, 0, 0.85) 86%,
          rgba(0, 0, 0, 0.35) 93%,
          rgba(0, 0, 0, 0) 100%
        );
      }

      .headerGradientBlur > div:nth-of-type(1) {
        z-index: 2;
        -webkit-backdrop-filter: blur(0.5px) saturate(1.35);
        backdrop-filter: blur(0.5px) saturate(1.35);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 44%,
          rgba(0, 0, 0, 0.35) 54%,
          rgba(0, 0, 0, 0.9) 64%,
          rgba(0, 0, 0, 1) 69%,
          rgba(0, 0, 0, 0.9) 76%,
          rgba(0, 0, 0, 0.35) 84%,
          rgba(0, 0, 0, 0) 92%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 44%,
          rgba(0, 0, 0, 0.35) 54%,
          rgba(0, 0, 0, 0.9) 64%,
          rgba(0, 0, 0, 1) 69%,
          rgba(0, 0, 0, 0.9) 76%,
          rgba(0, 0, 0, 0.35) 84%,
          rgba(0, 0, 0, 0) 92%
        );
      }

      .headerGradientBlur > div:nth-of-type(2) {
        z-index: 3;
        -webkit-backdrop-filter: blur(0.625px) saturate(1.35);
        backdrop-filter: blur(0.625px) saturate(1.35);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 32%,
          rgba(0, 0, 0, 0.35) 42%,
          rgba(0, 0, 0, 0.92) 52%,
          rgba(0, 0, 0, 1) 57%,
          rgba(0, 0, 0, 0.92) 65%,
          rgba(0, 0, 0, 0.35) 74%,
          rgba(0, 0, 0, 0) 82%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 32%,
          rgba(0, 0, 0, 0.35) 42%,
          rgba(0, 0, 0, 0.92) 52%,
          rgba(0, 0, 0, 1) 57%,
          rgba(0, 0, 0, 0.92) 65%,
          rgba(0, 0, 0, 0.35) 74%,
          rgba(0, 0, 0, 0) 82%
        );
      }

      .headerGradientBlur > div:nth-of-type(3) {
        z-index: 4;
        -webkit-backdrop-filter: blur(1.25px) saturate(1.4);
        backdrop-filter: blur(1.25px) saturate(1.4);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 20%,
          rgba(0, 0, 0, 0.4) 30%,
          rgba(0, 0, 0, 0.95) 40%,
          rgba(0, 0, 0, 1) 45%,
          rgba(0, 0, 0, 0.95) 53%,
          rgba(0, 0, 0, 0.4) 62%,
          rgba(0, 0, 0, 0) 72%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 20%,
          rgba(0, 0, 0, 0.4) 30%,
          rgba(0, 0, 0, 0.95) 40%,
          rgba(0, 0, 0, 1) 45%,
          rgba(0, 0, 0, 0.95) 53%,
          rgba(0, 0, 0, 0.4) 62%,
          rgba(0, 0, 0, 0) 72%
        );
      }

      .headerGradientBlur > div:nth-of-type(4) {
        z-index: 5;
        -webkit-backdrop-filter: blur(2.5px) saturate(1.45);
        backdrop-filter: blur(2.5px) saturate(1.45);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 8%,
          rgba(0, 0, 0, 0.4) 18%,
          rgba(0, 0, 0, 0.95) 28%,
          rgba(0, 0, 0, 1) 33%,
          rgba(0, 0, 0, 0.95) 41%,
          rgba(0, 0, 0, 0.4) 50%,
          rgba(0, 0, 0, 0) 60%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0) 8%,
          rgba(0, 0, 0, 0.4) 18%,
          rgba(0, 0, 0, 0.95) 28%,
          rgba(0, 0, 0, 1) 33%,
          rgba(0, 0, 0, 0.95) 41%,
          rgba(0, 0, 0, 0.4) 50%,
          rgba(0, 0, 0, 0) 60%
        );
      }

      .headerGradientBlur > div:nth-of-type(5) {
        z-index: 6;
        -webkit-backdrop-filter: blur(5px) saturate(1.5);
        backdrop-filter: blur(5px) saturate(1.5);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0.35) 6%,
          rgba(0, 0, 0, 0.95) 16%,
          rgba(0, 0, 0, 1) 21%,
          rgba(0, 0, 0, 0.95) 29%,
          rgba(0, 0, 0, 0.35) 38%,
          rgba(0, 0, 0, 0) 48%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0.35) 6%,
          rgba(0, 0, 0, 0.95) 16%,
          rgba(0, 0, 0, 1) 21%,
          rgba(0, 0, 0, 0.95) 29%,
          rgba(0, 0, 0, 0.35) 38%,
          rgba(0, 0, 0, 0) 48%
        );
      }

      .headerGradientBlur > div:nth-of-type(6) {
        z-index: 7;
        -webkit-backdrop-filter: blur(10px) saturate(1.55);
        backdrop-filter: blur(10px) saturate(1.55);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.2) 0%,
          rgba(0, 0, 0, 0.85) 10%,
          rgba(0, 0, 0, 1) 16%,
          rgba(0, 0, 0, 0.92) 24%,
          rgba(0, 0, 0, 0.45) 34%,
          rgba(0, 0, 0, 0.1) 44%,
          rgba(0, 0, 0, 0) 54%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.2) 0%,
          rgba(0, 0, 0, 0.85) 10%,
          rgba(0, 0, 0, 1) 16%,
          rgba(0, 0, 0, 0.92) 24%,
          rgba(0, 0, 0, 0.45) 34%,
          rgba(0, 0, 0, 0.1) 44%,
          rgba(0, 0, 0, 0) 54%
        );
      }

      .headerGradientBlur::after {
        content: "";
        z-index: 8;
        -webkit-backdrop-filter: blur(20px) saturate(1.6);
        backdrop-filter: blur(20px) saturate(1.6);
        -webkit-mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.95) 0%,
          rgba(0, 0, 0, 1) 4%,
          rgba(0, 0, 0, 0.88) 12%,
          rgba(0, 0, 0, 0.5) 22%,
          rgba(0, 0, 0, 0.18) 32%,
          rgba(0, 0, 0, 0) 42%
        );
        mask-image: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.95) 0%,
          rgba(0, 0, 0, 1) 4%,
          rgba(0, 0, 0, 0.88) 12%,
          rgba(0, 0, 0, 0.5) 22%,
          rgba(0, 0, 0, 0.18) 32%,
          rgba(0, 0, 0, 0) 42%
        );
      }

      .headerFxTint {
        position: absolute;
        inset: 0;
