---
import "../styles/global.css";

const { title = "NikolayP2" } = Astro.props;

import avatarSrc from "../images/avatar.jpg";
import { profileLinks } from "../config/links";

const header = {
  name: "Nikolai Posvezhnyi",
  avatarSrc: avatarSrc.src,
  ...profileLinks,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="header">
      <div class="nav">
        <div class="brand" aria-label="Author">
          <a class="brandLink" href="/">
            <img
              class="avatar"
              src={header.avatarSrc}
              alt={`${header.name} avatar`}
            />
            <span class="brandName">{header.name}</span>
          </a>
        </div>

        <nav class="navLinks desktop-only" aria-label="External links">
          <a href={header.cvUrl} target="_blank" rel="noreferrer noopener">CV</a>
          <a href={header.linkedInUrl} target="_blank" rel="noreferrer noopener">LinkedIn</a>
          <a href={header.aboutUrl}>About</a>
          <a href={`mailto:${header.email}`}>Email</a>
          <a href={header.telegramUrl} target="_blank" rel="noreferrer noopener">Telegram</a>
        </nav>

        <nav class="navLinks mobile-only" aria-label="External links">
          <button>
            <span class="navLinksLabel">Contacts</span>
            <span class="icon-plus" aria-hidden="true"></span>
          </button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="footer">
      <div class="container footerInner">
        <div class="footerCopy">© 2026 Nikolai Posvezhnyi + AI = ❤</div>
        <div class="footerLinks desktop-only">
          <div class="footerLink">
            <a href={`mailto:${profileLinks.email}`}>{profileLinks.email}</a>
          </div>
          <div class="footerLink">
            <span class="footerLinkLabel">tg:</span>
            <a href={profileLinks.telegramUrl} target="_blank" rel="noreferrer noopener">
              {profileLinks.telegramHandle}
            </a>
          </div>
        </div>
      </div>
    </footer>

    <style>
      .header {
        padding: 1.388vw 2.083vw 1.388vw 1.388vw;
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .brandLink {
        display: flex;
        align-items: center;
        gap: 0.6944vw;
      }

      .avatar {
        border-radius: 999px;
        display: block;
        object-fit: cover;
        width: 2.778vw;
        height: 2.778vw;
      }

      .navLinks {
        display: flex;
        gap: 1.388vw;
      }
      .navLinks.mobile-only {
        display: none;
      }

      .navLinks button {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        margin: 0;
      }

      nav {
        display: flex;
      }

      .footerInner {
        border-top: 1px solid var(--color-gray);
        color: rgba(0, 0, 0, 0.3);
        padding: 2.0833vw 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.041vw;
      }

      .footerCopy {
        white-space: nowrap;
      }

      .footerLinks {
        display: flex;
        gap: 1.736vw;
      }

      .footerLink a {
        color: var(--color-fg);
      }

      @media (max-width: 600px) {
        .navLinks.desktop-only {
          display: none;
        }
        .navLinks.mobile-only {
          display: block;
        }
        .navLinks button {
          display: flex;
          font-size: 4vw;
          line-height: 1.25;
          gap: 1.333vw;
        }
        .navLinks .icon-plus {
          width: 3.73vw;
          height: 3.73vw;
          margin-top: 0.633vw;
          vertical-align: top;
        }
        .header {
          padding: 4vw;
        }
        .brandLink {
          gap: 1.3333vw;
        }

        .avatar {
          width: 5.3333vw;
          height: 5.3333vw;
        }

        .footer {
          flex-direction: column;
          align-items: flex-start;
          padding: 0 4vw;
        }
        .footerInner {
          padding: 6.6667vw 0;
        }
        .footerLinks {
          display: none;
        }
      }
    </style>
  </body>
</html>

