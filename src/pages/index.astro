---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrimaryButton from "../components/PrimaryButton.astro";
---

<BaseLayout title="Home">
  <h1>Home</h1>
  <p>
    Static site base powered by Astro. Primary styles use Inter Tight and your
    color palette.
  </p>
  <div
    style="margin-top: 18px; display: flex; gap: 12px; flex-wrap: wrap;"
  >
    <PrimaryButton href="/cases" text="View cases" />
    <PrimaryButton href="/about" text="About us" />
  </div>
</BaseLayout>
