---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profileLinks } from "../config/links";
import { cases } from "../config/cases";
import HomePreviewSlider from "../components/HomePreviewSlider.astro";
import CaseParagraphBlocks from "../components/CaseParagraphBlocks.astro";
import { extraShots } from "../config/extraShots";

function previewItems(caseItem: (typeof cases)[number]) {
  if (
    "preview" in caseItem &&
    Array.isArray(caseItem.preview) &&
    caseItem.preview.length > 0
  ) {
    return caseItem.preview;
  }
  return [
    {
      type: "image" as const,
      image: caseItem.image,
      imageAlt: caseItem.imageAlt,
    },
  ];
}
---

<BaseLayout title="Nikolai Posvezhnyi - Senior Product Designer">
  <section class="hero">
    <div class="heroInner">
      <h1 class="heroTitle">Senior Product&nbsp;Designer</h1>
      <h2 class="heroAccent">7+ Years in Web3 <span class="desktop-only">/</span> Crypto / Growth</h2>
      <p class="heroDescription">
        Designing web &amp; mobile experiences where data-driven thinking meets
        emotional design. Inspiring teams. Delivering efficiently.
      </p>

      <div class="heroActions">
        <a
          class="primaryButton heroEmail"
          href={`mailto:${profileLinks.email}`}
        >
          Email Me
        </a>
        <a
          class="primaryButton heroTelegram"
          href={profileLinks.telegramUrl}
          target="_blank"
          rel="noreferrer noopener"
          aria-label="Telegram"
        >
          <span class="icon-telegram" aria-hidden="true"></span>
        </a>
      </div>
    </div>
  </section>

  {cases.map((caseItem) => (
    <section class="homeCase" aria-labelledby={`case-${caseItem.id}-title`}>
      <div class="caseTop">
        <div class="caseHeading">
          <div class="caseBrand">{caseItem.brand}</div>
          <h3 id={`case-${caseItem.id}-title`} class="caseTitle">
            {caseItem.title}
          </h3>
          <div class="caseMeta">
            <div class="caseMeta-item">{caseItem.meta.dateRange}</div>
            <div class="caseMeta-item">/</div>
            <div class="caseMeta-item">{caseItem.meta.location}</div>
            <div class="caseMeta-item desktop-only">/</div>
            <div class="caseMeta-item desktop-only">{caseItem.meta.stack}</div>
            <div class="caseMeta-item desktop-only">/</div>
            <div class="caseMeta-item desktop-only">{caseItem.meta.roles}</div>
          </div>
        </div>

        <div class="casePreview mobile-only">
          <HomePreviewSlider
            items={previewItems(caseItem)}
            ariaLabel={`${caseItem.brand} preview`}
          />
        </div>

        <div class="caseInfo">
          <div>
            <h4>Goal</h4>
            <p>{caseItem.goal}</p>
            {caseItem.public ? (
              <a class="caseDetails" href={caseItem.detailsUrl}>Details →</a>
            ) : (
              <span class="caseDetails __coming-soon">Details Coming Soon</span>
            )}
          </div>
          <div>
            <h4>Impact</h4>
            <p>{caseItem.impact}</p>
          </div>
        </div>
        {caseItem.public && <a class="caseLink" href={caseItem.detailsUrl}></a>}
      </div>

      <div class="casePreview desktop-only">
        <HomePreviewSlider
          items={previewItems(caseItem)}
          ariaLabel={`${caseItem.brand} preview`}
        />
      </div>
    </section>
  ))}
  <details class="extraShotsDetails">
    <summary class="extraShots">
      <span class="extraShotsLabel extraShotsLabel--closed">See Some Extra Shots</span>
      <span class="extraShotsLabel extraShotsLabel--open">Hide Extra Shots</span>
      <span class="extraShotsPlus" aria-hidden="true">
        <span class="icon-plus extraShotsIcon extraShotsIcon--closed" aria-hidden="true"></span>
        <span class="icon-minus extraShotsIcon extraShotsIcon--open" aria-hidden="true"></span>
      </span>
    </summary>
    <div class="extraShotsBody">
      <CaseParagraphBlocks blocks={extraShots} />
    </div>
  </details>

  <script is:inline>
    (function () {
      function initSlider(root) {
        if (root.getAttribute("data-slider-inited") === "1") return;
        root.setAttribute("data-slider-inited", "1");
        var viewport = root.querySelector(".caseImagesSliderViewport");
        var inner = root.querySelector(".caseImagesSliderInner");
        var slides = root.querySelectorAll(".caseImagesSliderSlide");
        var dots = root.querySelectorAll(".caseImagesSliderDot");
        var prev = root.querySelector(".caseImagesSliderNavPrev");
        var next = root.querySelector(".caseImagesSliderNavNext");
        if (!viewport || slides.length < 2) return;

        var index = 0;
        var scrollEndTimer;

        function updateDots() {
          for (var i = 0; i < dots.length; i++) {
            dots[i].classList.toggle("is-active", i === index);
            dots[i].setAttribute(
              "aria-current",
              i === index ? "true" : "false"
            );
          }
        }

        function updateAria() {
          for (var i = 0; i < slides.length; i++) {
            slides[i].setAttribute(
              "aria-hidden",
              i === index ? "false" : "true"
            );
          }
        }

        function goTo(i) {
          var n = slides.length;
          if (n === 0) return;
          var nextIdx = ((i % n) + n) % n;
          var wrapAround =
            (index === n - 1 && nextIdx === 0) ||
            (index === 0 && nextIdx === n - 1);
          index = nextIdx;
          var slide = slides[index];
          viewport.scrollTo({
            left: slide.offsetLeft,
            behavior: wrapAround ? "auto" : "smooth",
          });
          updateDots();
          updateAria();
        }

        function readIndexFromScroll() {
          var w = viewport.clientWidth;
          var x = viewport.scrollLeft + w / 2;
          var closest = 0;
          var best = Infinity;
          for (var i = 0; i < slides.length; i++) {
            var s = slides[i];
            var mid = s.offsetLeft + s.offsetWidth / 2;
            var d = Math.abs(mid - x);
            if (d < best) {
              best = d;
              closest = i;
            }
          }
          if (closest !== index) {
            index = closest;
            updateDots();
            updateAria();
          }
        }

        if (prev)
          prev.addEventListener("click", function () {
            goTo(index - 1);
          });
        if (next)
          next.addEventListener("click", function () {
            goTo(index + 1);
          });
        for (var d = 0; d < dots.length; d++) {
          (function (i) {
            dots[i].addEventListener("click", function () {
              goTo(i);
            });
          })(d);
        }

        viewport.addEventListener(
          "scroll",
          function () {
            clearTimeout(scrollEndTimer);
            scrollEndTimer = setTimeout(readIndexFromScroll, 80);
          },
          { passive: true }
        );

        viewport.addEventListener("keydown", function (e) {
          if (e.key === "ArrowLeft") {
            e.preventDefault();
            goTo(index - 1);
          }
          if (e.key === "ArrowRight") {
            e.preventDefault();
            goTo(index + 1);
          }
        });

        var tapTrack = null;
        var TAP_MOVE_PX = 14;
        viewport.addEventListener("pointerdown", function (e) {
          if (e.pointerType === "mouse" && e.button !== 0) return;
          tapTrack = {
            id: e.pointerId,
            x: e.clientX,
            y: e.clientY,
            cancelled: false,
          };
        });
        viewport.addEventListener("pointermove", function (e) {
          if (!tapTrack || tapTrack.id !== e.pointerId) return;
          if (
            Math.abs(e.clientX - tapTrack.x) > TAP_MOVE_PX ||
            Math.abs(e.clientY - tapTrack.y) > TAP_MOVE_PX
          ) {
            tapTrack.cancelled = true;
          }
        });
        function clearTap(e) {
          if (!tapTrack || tapTrack.id !== e.pointerId) return;
          var t = tapTrack;
          tapTrack = null;
          if (t.cancelled) return;
          var rect = viewport.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;
          if (x < 0 || x > rect.width || y < 0 || y > rect.height) return;
          if (x < rect.width / 2) goTo(index - 1);
          else goTo(index + 1);
        }
        viewport.addEventListener("pointerup", clearTap);
        viewport.addEventListener("pointercancel", function (e) {
          if (tapTrack && tapTrack.id === e.pointerId) tapTrack = null;
        });

        if (inner && prev && next) {
          function clearHalfHover() {
            root.classList.remove("caseImagesSlider--half-left");
            root.classList.remove("caseImagesSlider--half-right");
          }
          function updateHalfHover(clientX) {
            var rect = inner.getBoundingClientRect();
            var x = clientX - rect.left;
            if (x < rect.width * 0.5) {
              root.classList.add("caseImagesSlider--half-left");
              root.classList.remove("caseImagesSlider--half-right");
            } else {
              root.classList.remove("caseImagesSlider--half-left");
              root.classList.add("caseImagesSlider--half-right");
            }
          }
          inner.addEventListener("pointermove", function (e) {
            if (e.pointerType === "touch") return;
            updateHalfHover(e.clientX);
          });
          inner.addEventListener("pointerleave", clearHalfHover);
        }
      }

      document
        .querySelectorAll(".homePreviewSliderWrap .caseImagesSlider")
        .forEach(initSlider);

      document.querySelectorAll(".extraShotsDetails").forEach(function (det) {
        det.addEventListener("toggle", function () {
          if (!det.open) return;
          det
            .querySelectorAll(".extraShotsBody .caseImagesSlider")
            .forEach(initSlider);
        });
      });
    })();
  </script>

  <style>
    .hero {
      padding: 6.9444vw 0;
    }
    .hero.__bottom {
      padding: 12.5vw 0;
    }

    .heroInner {
      margin: 0 auto;
      text-align: center;
    }

    .heroTitle {
      color: var(--color-fg);
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin: 0;
    }

    .heroAccent {
      margin: 0 0 1.388vw 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--color-primary);
      letter-spacing: -0.02em;
    }

    .heroDescription {
      margin: 0 auto 0;
      max-width: 33.333vw;
    }

    .heroActions {
      margin-top: 1.736vw;
      display: flex;
      justify-content: center;
      gap: 0.3472vw;
      align-items: center;
      flex-wrap: wrap;
    }

    .heroEmail {
      width: 12.5vw;
    }
    .heroTelegram {
    }

    .homeCase {
      border-top: 1px solid #d9d9d9;
      padding: 0 0 3.472vw 0;
    }

    .caseTop {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.700vw;
      align-items: start;
      padding: 3.472vw 0;
      position: relative;
    }
    .caseLink {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    .caseBrand {
      color: var(--color-primary);
      font-size: 1.388vw;
      line-height: 1;
      margin: 0 0 1.04167vw;
    }

    .caseTitle {
      margin: 0;
      font-size: 2.43056vw;
      line-height: 1.2;
      letter-spacing: -0.015em;
      font-weight: 500;
      margin: 0 0 1.04167vw;
    }

    .caseMeta {
      color: rgba(0, 0, 0, 0.3);
      display: flex;
      gap: 0.6944vw;
    }

    .caseInfo {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.736vw;
    }

    .caseInfo h4 {
      font-size: 1.3889vw;
      font-weight: 500;
      line-height: 1;
      margin: 0 0 1.04167vw;
    }

    .caseInfo p {
      margin: 0 0 1.04167vw;
    }

    .caseDetails {
      color: var(--color-primary);
      position: relative;
      z-index: 2;
    }
    .caseDetails:hover {
      color: var(--color-primary-hover);
    }
    .caseDetails.__coming-soon {
      color: rgba(0, 0, 0, 0.3);
      cursor: default;
    }
    .caseDetails.__coming-soon:hover {
      color: rgba(0, 0, 0, 0.3);
    }

    .caseTop:hover .caseTitle {
      color: var(--color-primary-hover);
    }

    .casePreview {
      position: relative;
      z-index: 2;
    }

    .casePreview:has(.caseImagesSlider) {
      overflow: visible;
    }

    .homeBottom {
      border-top: 1px solid #d9d9d9;
      padding: 0 0 1.736vw;
    }

    .extraShotsDetails {
      border-bottom: 1px solid #d9d9d9;
      border-top: 1px solid #d9d9d9;
    }

    .extraShotsDetails[open] {
      border-bottom: none;
    }

    .extraShotsDetails summary.extraShots {
      display: flex;
      align-items: center;
      height: 5.5556vw;
      justify-content: space-between;
      list-style: none;
      cursor: pointer;
      padding: 2.0833vw 0;
      position: relative;
    }

    .extraShotsDetails summary.extraShots::-webkit-details-marker {
      display: none;
    }

    .extraShotsDetails:hover .extraShotsLabel,
    .extraShotsDetails:hover .extraShotsPlus {
      color: var(--color-primary-hover);
    }

    .extraShotsDetails[open] summary.extraShots {
      height: auto;
      min-height: 5.5556vw;
    }

    .extraShotsBody {
      margin-top: -1.3889vw;
      padding: 0 0 2.0833vw;
    }

    .extraShotsLabel--open {
      display: none;
    }

    .extraShotsDetails[open] .extraShotsLabel--closed {
      display: none;
    }

    .extraShotsDetails[open] .extraShotsLabel--open {
      display: block;
    }

    .extraShotsIcon {
      display: inline-block;
    }

    .extraShotsIcon--open {
      display: none;
    }

    .extraShotsDetails[open] .extraShotsIcon--closed {
      display: none;
    }

    .extraShotsDetails[open] .extraShotsIcon--open {
      display: inline-block;
    }

    .extraShotsLabel {
      color: var(--color-primary);
      font-size: 1.3889vw;
      line-height: 1;
      transition: all 0.2s ease-in-out;
    }

    .extraShotsPlus {
      color: var(--color-primary);
      height: 1.3889vw;
      transition: all 0.2s ease-in-out;
      width: 1.3889vw;
    }

    .bottomCta {
      padding: 10.416vw 0;
      text-align: center;
    }

    .bottomCtaTitle {
      margin: 0;
      color: var(--color-fg);
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    .bottomCtaAccent {
      margin: 0 0 1.388vw 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--color-primary);
    }

    @media (min-width: 1440px) {
      .hero {
        padding: 100px 0;
      }

      .hero.__bottom {
        padding: 180px 0;
      }

      .heroTitle,
      .heroAccent,
      .bottomCtaTitle,
      .bottomCtaAccent {
        font-size: 50px;
      }

      .heroAccent,
      .bottomCtaAccent {
        margin-bottom: 20px;
      }

      .heroDescription {
        max-width: 480px;
      }

      .heroActions {
        margin-top: 25px;
        gap: 5px;
      }

      .heroEmail {
        width: 180px;
      }

      .homeCase {
        padding-bottom: 50px;
      }

      .caseTop {
        gap: 10px;
        padding: 50px 0;
      }

      .caseBrand,
      .extraShotsLabel,
      .extraShotsNextCase {
        font-size: 20px;
      }

      .caseTitle {
        font-size: 35px;
        margin-bottom: 15px;
      }

      .caseMeta {
        gap: 11px;
      }

      .caseInfo {
        gap: 20px;
      }

      .caseInfo h4 {
        font-size: 20px;
        margin-bottom: 15px;
      }

      .caseInfo p {
        margin-bottom: 15px;
      }

      .casePreview {
        border-radius: 12px;
      }

      .extraShotsDetails summary.extraShots {
        height: 82px;
        padding: 30px 0;
      }

      .extraShotsDetails[open] summary.extraShots {
        min-height: 82px;
      }

      .extraShotsBody {
        margin-top: -20px;
        padding: 0 0 30px;
      }

      .extraShotsPlus {
        width: 20px;
        height: 20px;
      }

      .bottomCta {
        padding: 150px 0;
      }
    }


    @media (max-width: 600px) {
      .hero {
        padding: 34.6667vw 0 26.6667vw;
      }
      .hero.__bottom {
        padding: 40vw 0;
      }
      .heroTitle {
        font-size: 12vw;
        line-height: 1;
        margin: 0 0 1.333vw 0;
      }
      .heroAccent {
        font-size: 12vw;
        line-height: 1;
        margin: 0 0 6.6667vw 0;
      }

      .heroDescription {
        max-width: 100vw;
      }

      .heroActions {
        margin-top: 6.666vw;
        gap: 1.333vw;
      }

      .heroEmail {
        width: 48vw;
      }
      .heroTelegram {
        width: 16vw;
      }

      .homeCase {
        padding: 0 0 5.3vw 0;
      }
      
      .caseTop {
        grid-template-columns: 1fr;
      }

      .caseTop {
        gap: 8vw;
        padding: 8vw 0;
      }
      .caseBrand {
        font-size: 4.8vw;
        line-height: 5.3333vw;
        margin: 0 0 2.6667vw;
      }
      .caseTitle {
        font-size: 8vw;
        line-height: 8.7vw;
        margin: 0 0 2.6667vw;
      }
      .caseMeta {
        gap: 1.333vw;
      }
      .caseInfo {
        gap: 3.8vw;
      }
      .caseInfo h4 {
        font-size: 4.8vw;
        line-height: 5.333vw;
        margin: 0 0 2.6667vw;
      }
      .caseInfo p {
        margin: 0 0 2.6667vw;
        line-height: 1.27;
      }
      .casePreview {
        border-radius: 0.833vw;
        margin: 0;
      }

      .casePreview:has(.homePreviewSliderWrap) {
        padding-bottom: 0;
      }

      .extraShotsDetails summary.extraShots {
        height: auto;
        min-height: 5.694vw;
        padding: 6.6667vw 0;
      }

      .extraShotsBody {
        margin-top: -5.333vw;
        padding: 0 0 4vw;
      }

      .extraShotsLabel {
        font-size: 4.8vw;
        line-height: 5.333vw;
      }

      .extraShotsPlus {
        width: 5.3vw;
        height: 5.3vw;
      }

      .bottomCta {
        padding: 88px 0;
      }

      .bottomCtaTitle,
      .bottomCtaAccent {
        font-size: 36px;
      }
    }
  </style>
</BaseLayout>
