---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profileLinks } from "../config/links";
import { homeCases } from "../config/homeCases";
import "../styles/icons.css";
---

<BaseLayout title="Nikolai Posvezhnyi - Senior Product Designer">
  <section class="hero">
    <div class="heroInner">
      <h1 class="heroTitle">Senior Product&nbsp;Designer</h1>
      <h2 class="heroAccent">7+ Years in Web3 <span class="desktop-only">/</span> Crypto / Growth</h2>
      <p class="heroDescription">
        Designing web &amp; mobile experiences where data-driven thinking meets
        emotional design. Inspiring teams. Delivering efficiently.
      </p>

      <div class="heroActions">
        <a
          class="primaryButton heroEmail"
          href={`mailto:${profileLinks.email}`}
        >
          Email Me
        </a>
        <a
          class="primaryButton heroTelegram"
          href={profileLinks.telegramUrl}
          target="_blank"
          rel="noreferrer noopener"
          aria-label="Telegram"
        >
          <span class="icon-telegram" aria-hidden="true"></span>
        </a>
      </div>
    </div>
  </section>

  {homeCases.map((caseItem) => (
    <section class="homeCase" aria-labelledby={`case-${caseItem.id}-title`}>
      <div class="caseTop">
        <div class="caseHeading">
          <div class="caseBrand">{caseItem.brand}</div>
          <h3 id={`case-${caseItem.id}-title`} class="caseTitle">
            {caseItem.title}
          </h3>
          <div class="caseMeta">
            <div class="caseMeta-item">{caseItem.meta.dateRange}</div>
            <div class="caseMeta-item">/</div>
            <div class="caseMeta-item">{caseItem.meta.location}</div>
            <div class="caseMeta-item desktop-only">/</div>
            <div class="caseMeta-item desktop-only">{caseItem.meta.stack}</div>
            <div class="caseMeta-item desktop-only">/</div>
            <div class="caseMeta-item desktop-only">{caseItem.meta.roles}</div>
          </div>
        </div>

        <div class="casePreview mobile-only">
          <img
            class="casePreviewImage"
            src={caseItem.image.src}
            alt={caseItem.imageAlt}
            loading="lazy"
          />
        </div>

        <div class="caseInfo">
          <div>
            <h4>Goal</h4>
            <p>{caseItem.goal}</p>
            <a class="caseDetails" href={caseItem.detailsUrl}>Details →</a>
          </div>
          <div>
            <h4>Impact</h4>
            <p>{caseItem.impact}</p>
          </div>
        </div>
        <a class="caseLink" href={caseItem.detailsUrl}></a>
      </div>

      <div class="casePreview desktop-only">
        <img
          class="casePreviewImage"
          src={caseItem.image.src}
          alt={caseItem.imageAlt}
          loading="lazy"
        />
      </div>
    </section>
  ))}

  <section class="homeBottom" aria-label="Extra shots and contact call to action">
    <div class="extraShots">
      <span class="extraShotsLabel">See Some Extra Shots</span>
      <span class="extraShotsPlus" aria-hidden="true">
        <span class="icon-plus" aria-hidden="true"></span>
      </span>
      <a class="extraShotsLink" href="/cases"></a>
    </div>

    <div class="hero __bottom">
      <div class="heroInner">
        <h3 class="heroTitle">Building something bold?</h3>
        <p class="heroAccent">Let&apos;s design it right.</p>
        <div class="heroActions">
          <a class="primaryButton heroEmail" href={`mailto:${profileLinks.email}`}>
            Email Me
          </a>
          <a
            class="primaryButton heroTelegram"
            href={profileLinks.telegramUrl}
            target="_blank"
            rel="noreferrer noopener"
            aria-label="Telegram"
          >
            <span class="icon-telegram" aria-hidden="true"></span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero {
      padding: 6.9444vw 0;
    }
    .hero.__bottom {
      padding: 12.5vw 0;
    }

    .heroInner {
      margin: 0 auto;
      text-align: center;
    }

    .heroTitle {
      color: var(--color-fg);
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin: 0;
    }

    .heroAccent {
      margin: 0 0 1.388vw 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--color-primary);
      letter-spacing: -0.02em;
    }

    .heroDescription {
      margin: 0 auto 0;
      max-width: 33.333vw;
    }

    .heroActions {
      margin-top: 1.736vw;
      display: flex;
      justify-content: center;
      gap: 0.3472vw;
      align-items: center;
      flex-wrap: wrap;
    }

    .heroEmail {
      width: 12.5vw;
    }
    .heroTelegram {
    }

    .homeCase {
      border-top: 1px solid #d9d9d9;
      padding: 0 0 3.472vw 0;
    }

    .caseTop {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.700vw;
      align-items: start;
      padding: 3.472vw 0;
      position: relative;
    }
    .caseLink {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    .caseBrand {
      color: var(--color-primary);
      font-size: 1.388vw;
      line-height: 1;
      margin: 0 0 1.04167vw;
    }

    .caseTitle {
      margin: 0;
      font-size: 2.43056vw;
      line-height: 1;
      letter-spacing: -0.015em;
      font-weight: 500;
      margin: 0 0 1.04167vw;
    }

    .caseMeta {
      color: rgba(0, 0, 0, 0.3);
      display: flex;
      gap: 0.6944vw;
    }

    .caseInfo {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.736vw;
    }

    .caseInfo h4 {
      font-size: 1.3889vw;
      font-weight: 500;
      margin: 0 0 1.04167vw;
    }

    .caseInfo p {
      margin: 0 0 1.04167vw;
    }

    .caseDetails {
      color: var(--color-primary);
    }

    .caseTop:hover .caseTitle,
    .caseTop:hover .caseTitle {
      color: var(--color-primary-hover);
    }

    .casePreview {
      border-radius: 0.833vw;
      background: #efefef;
      overflow: hidden;
    }

    .casePreviewImage {
      display: block;
      width: 100%;
      height: auto;
    }

    .homeBottom {
      border-top: 1px solid #d9d9d9;
      padding: 0 0 1.736vw;
    }

    .extraShots {
      display: flex;
      align-items: center;
      height: 5.5556vw;
      justify-content: space-between;
      border-bottom: 1px solid #d9d9d9;
      padding: 2.0833vw 0;
      position: relative;
    }

    .extraShotsLabel {
      color: var(--color-primary);
      font-size: 1.3889vw;
      line-height: 1;
    }
    .extraShotsLink {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    .extraShotsPlus {
      color: var(--color-primary);
      height: 1.3889vw;
      width: 1.3889vw;
    }

    .bottomCta {
      padding: 10.416vw 0;
      text-align: center;
    }

    .bottomCtaTitle {
      margin: 0;
      color: var(--color-fg);
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    .bottomCtaAccent {
      margin: 0 0 1.388vw 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      color: var(--color-primary);
    }


    @media (max-width: 600px) {
      .hero {
        padding: 34.6667vw 0 26.6667vw;
      }
      .hero.__bottom {
        padding: 40vw 0;
      }
      .heroTitle {
        font-size: 12vw;
        line-height: 1;
        margin: 0 0 1.333vw 0;
      }
      .heroAccent {
        font-size: 12vw;
        line-height: 1;
        margin: 0 0 6.6667vw 0;
      }

      .heroDescription {
        max-width: 100vw;
      }

      .heroActions {
        margin-top: 6.666vw;
        gap: 1.333vw;
      }

      .heroEmail {
        width: 48vw;
      }
      .heroTelegram {
        width: 16vw;
      }

      .homeCase {
        padding: 0 0 5.3vw 0;
      }
      
      .caseTop {
        grid-template-columns: 1fr;
      }

      .caseTop {
        gap: 8vw;
        padding: 8vw 0;
      }
      .caseBrand {
        font-size: 4.8vw;
        line-height: 5.3333vw;
        margin: 0 0 2.6667vw;
      }
      .caseTitle {
        font-size: 8vw;
        line-height: 8.533vw;
        margin: 0 0 2.6667vw;
      }
      .caseMeta {
        gap: 1.333vw;
      }
      .caseInfo {
        gap: 1.736vw;
      }
      .caseInfo h4 {
        font-size: 4.8vw;
        line-height: 5.333vw;
        margin: 0 0 2.6667vw;
      }
      .caseInfo p {
        margin: 0 0 2.6667vw;
      }
      .casePreview {
        border-radius: 0.833vw;
        margin: 0;
      }

      .extraShots {
        height: 18.6667vw;
        padding: 6.6667vw 0;
      }
      .extraShotsLabel {
        font-size: 4.8vw;
        line-height: 5.333vw;
      }
      .extraShotsLink {
      }
      .extraShotsPlus {
        width: 5.3vw;
        height: 5.3vw;
      }

      .bottomCta {
        padding: 88px 0;
      }

      .bottomCtaTitle,
      .bottomCtaAccent {
        font-size: 36px;
      }
    }
  </style>
</BaseLayout>
