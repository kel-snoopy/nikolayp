---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrimaryButton from "../components/PrimaryButton.astro";
import { homeCases } from "../config/homeCases";
---

<BaseLayout title="Cases">
  <h1>Cases</h1>
  <p>Examples of work can live here. Use `PrimaryButton` to keep actions consistent.</p>

  <div style="margin-top: 18px; display: flex; gap: 12px; flex-wrap: wrap;">
    <PrimaryButton href="/" text="Back home" />
  </div>

  <style>
    .caseGrid {
      margin-top: 22px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px;
    }

    .caseCard {
      border: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 12px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.6);
    }

    .caseThumb {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 10px;
      margin: 0 0 12px 0;
    }

    .caseCard h2 {
      margin: 0 0 8px 0;
      font-size: 16px;
    }

    .caseCard p {
      margin: 0;
      opacity: 0.9;
      font-size: 14px;
      line-height: 1.5;
    }
  </style>

  <div class="caseGrid">
    {homeCases.map((c) => (
      <div class="caseCard">
        <img class="caseThumb" src={c.image.src} alt={c.imageAlt} loading="lazy" />
        <h2>{c.brand}</h2>
        <p>{c.title}</p>
        <div style="margin-top: 12px;">
          <PrimaryButton href={c.detailsUrl} text="Open case" />
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

