---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/case-paragraph-blocks.css";
import "../../styles/case-images-slider.css";
import { cases } from "../../config/cases";
import playIconUrl from "../../images/icons/play.svg?url";

export function getStaticPaths() {
  return cases.map((c) => ({
    params: { slug: c.id },
  }));
}

const { slug } = Astro.params;
const slugStr = typeof slug === "string" ? slug : String(slug ?? "");
const caseItem = cases.find((c) => c.id === slugStr)!;
const caseSeo: Record<
  string,
  { title: string; description: string; ogImage: string; ogImageAlt: string }
> = {
  ankr: {
    title:
      "Ankr Case Study | Web3 Infrastructure Provider UI/UX & Product Design | Nikolai Posvezhnyi",
    description:
      "Driving audience growth and enterprise adoption by shaping the design language and product flows across Ankr’s website, products, and client solutions.",
    ogImage: "/og/ankr.png",
    ogImageAlt: "Ankr case study cover",
  },
  "path-crypto": {
    title:
      "Path Case Study | Crypto Investment Platform UI/UX & Product Design | Nikolai Posvezhnyi",
    description:
      "Designed a crypto investment platform from scratch under SEC compliance. UX, web and mobile apps, wallet flows, and product design case study.",
    ogImage: "/og/path-crypto.png",
    ogImageAlt: "Path case study cover",
  },
  neura: {
    title:
      "Neuraverse Case Study | Web3 Game UI/UX & Product Design | Nikolai Posvezhnyi",
    description:
      "Designed the UX for Neuraverse, a Web3 game driving 1M+ blockchain users. Game interface, onboarding, engagement systems, and product design process.",
    ogImage: "/og/neura.png",
    ogImageAlt: "Neuraverse case study cover",
  },
};
const seo = caseSeo[slugStr] ?? {
  title: `${caseItem.brand} | Nikolai Posvezhnyi`,
  description: caseItem.goal,
  ogImage: "/og/home.png",
  ogImageAlt: `${caseItem.brand} case cover`,
};

/** Vite imports `.mp4` as a string URL; images use `{ src }`. */
function videoUrl(video: string | { src: string }): string {
  return typeof video === "string" ? video : video.src;
}
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  ogImage={seo.ogImage}
  ogImageAlt={seo.ogImageAlt}
>
  <section class="casePage">
    <div class="caseTop">
      <div class="caseLeft">
        <p class="caseBrand">{caseItem.brand}</p>
        <h1 class="caseTitle">{caseItem.title}</h1>

        <div class="caseMeta">
          <span>{caseItem.meta.dateRange}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.location}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.stack}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.roles}</span>
        </div>
      </div>

      <div class="caseRight" set:html={caseItem.fullStoryText}></div>
    </div>

    {caseItem.paragraphs.map((p) => (
      <>
        {p.type === "video" && p.autoPlay !== false && (
          <div class="caseVideoPanel">
            <video
              class="caseVideo"
              autoplay
              loop
              muted
              playsinline
              preload="metadata"
              src={videoUrl(p.video)}
            >
              Your browser does not support the video tag.
            </video>
          </div>
        )}
        {p.type === "video" && p.autoPlay === false && (
          <div class="caseVideoPanel caseVideoPanel--manualPlay">
            <video
              class="caseVideo"
              preload="metadata"
              playsinline
              muted
              src={videoUrl(p.video)}
              poster={p.preview?.src}
              alt={p.previewAlt}
            >
              Your browser does not support the video tag.
            </video>
            <button
              type="button"
              class="caseVideoPlay"
              aria-label="Play video"
            >
              <img
                src={playIconUrl}
                alt=""
                width="35"
                height="47"
                loading="eager"
                decoding="async"
                draggable="false"
              />
            </button>
          </div>
        )}
        {p.type === "image" && (
          <div class="caseImagePanel">
            <img
              class="caseImage"
              src={p.image.src}
              alt={p.imageAlt}
              loading="lazy"
            />
          </div>
        )}
        {p.type === "half" && (
          <div class="caseHalfPanel">
            <div
              class="caseHalfGrid"
              role="group"
              aria-label="Split layout: UI and media"
            >
              {p.images.map((it) => (
                it.image ? (
                  <img
                    class="caseHalfImg"
                    src={it.image.src}
                    alt={it.imageAlt}
                    loading="lazy"
                  />
                ) : (
                  <video
                    class="caseHalfVideo"
                    autoplay
                    loop
                    muted
                    playsinline
                    preload="metadata"
                    src={videoUrl(it.video)}
                  >
                    Your browser does not support the video tag.
                  </video>
                )
              ))}
            </div>
          </div>
        )}
        {p.type === "images" && (
          <div class="caseImagesPanel">
            <div
              class="caseImagesSlider"
              role="region"
              aria-roledescription="carousel"
              aria-label="Case image gallery"
            >
              <div class="caseImagesSliderInner">
                <div
                  class:list={[
                    "caseImagesSliderViewport",
                    p.images.length > 1 && "caseImagesSliderViewport--seek",
                  ]}
                  tabindex={p.images.length > 1 ? 0 : undefined}
                >
                  <div class="caseImagesSliderTrack">
                    {p.images.map((image, slideIndex) => (
                      image.video ? (
                        <figure
                          class="caseImagesSliderSlide"
                          aria-hidden={slideIndex === 0 ? "false" : "true"}
                        >
                          <video
                            class="caseVideo caseImagesSliderImg"
                            autoplay
                            loop
                            muted
                            playsinline
                            preload="metadata"
                            src={videoUrl(image.video)}
                          >
                            Your browser does not support the video tag.
                          </video>
                        </figure>
                      ) : (
                        <figure
                          class="caseImagesSliderSlide"
                          aria-hidden={slideIndex === 0 ? "false" : "true"}
                        >
                          <img
                            class="caseImage caseImagesSliderImg"
                            src={image.image.src}
                            alt={image.imageAlt}
                            loading={slideIndex === 0 ? "eager" : "lazy"}
                            draggable="false"
                          />
                        </figure>
                      )
                    ))}
                  </div>
                </div>
                {p.images.length > 1 && (
                  <>
                    <button
                      type="button"
                      class="caseImagesSliderNav caseImagesSliderNavPrev"
                      aria-label="Previous slide"
                    >
                      <span class="icon-arrow-right" aria-hidden="true"></span>
                    </button>
                    <button
                      type="button"
                      class="caseImagesSliderNav caseImagesSliderNavNext"
                      aria-label="Next slide"
                    >
                      <span class="icon-arrow-right" aria-hidden="true"></span>
                    </button>
                  </>
                )}
              </div>
              {p.images.length > 1 && (
                <div
                  class="caseImagesSliderDots mobile-only"
                  role="tablist"
                  aria-label="Slides"
                >
                  {p.images.map((_, dotIndex) => (
                    <button
                      type="button"
                      class:list={[
                        "caseImagesSliderDot",
                        dotIndex === 0 && "is-active",
                      ]}
                      aria-label={`Go to slide ${dotIndex + 1}`}
                      aria-current={dotIndex === 0 ? "true" : "false"}
                    />
                  ))}
                </div>
              )}
            </div>
          </div>
        )}
        {p.type === "text" && (
          <div class:list={["caseParagraph", p.class]}>
            {"textBeforeTitle" in p && p.textBeforeTitle && (
              <div class="caseParagraphText" set:html={p.textBeforeTitle}></div>
            )}
            {"title" in p && p.title && <h2 class="caseParagraphTitle">{p.title}</h2>}
            <div class="caseParagraphText" set:html={p.text}></div>
          </div>
        )}
      </>
    ))}

    {caseItem.caseReviews.length > 0 && (
      <section class="caseReviews" aria-label="Case reviews">
        <div
          class="caseReviewsSlider"
          role="region"
          aria-roledescription="carousel"
          aria-label="Case reviews"
        >
          <div class="caseReviewsSliderInner">
            <div
              class:list={[
                "caseReviewsSliderViewport",
                caseItem.caseReviews.length > 1 &&
                  "caseReviewsSliderViewport--seek",
              ]}
              tabindex={caseItem.caseReviews.length > 1 ? 0 : undefined}
            >
              <div class="caseReviewsSliderTrack">
                {caseItem.caseReviews.map((review, reviewIndex) => (
                  <article
                    class="caseReviewCard caseReviewsSliderSlide"
                    aria-hidden={reviewIndex === 0 ? "false" : "true"}
                  >
                    <div class="caseReviewContent">
                      <img
                        class="caseReviewAvatar"
                        src={review.avatar.src}
                        alt={`${review.author} avatar`}
                        loading={reviewIndex === 0 ? "eager" : "lazy"}
                      />
                      <div class="caseReviewAuthor">{review.author}</div>
                      <div class="caseReviewRole">{review.role}</div>
                      <div class="caseReviewText" set:html={review.text}></div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            {caseItem.caseReviews.length > 1 && (
              <>
                <button
                  type="button"
                  class="caseReviewsSliderNav caseReviewsSliderNavPrev"
                  aria-label="Previous review"
                >
                  <span class="icon-arrow-right" aria-hidden="true"></span>
                </button>
                <button
                  type="button"
                  class="caseReviewsSliderNav caseReviewsSliderNavNext"
                  aria-label="Next review"
                >
                  <span class="icon-arrow-right" aria-hidden="true"></span>
                </button>
              </>
            )}
          </div>
          {caseItem.caseReviews.length > 1 && (
            <div
              class="caseReviewsSliderDots"
              role="tablist"
              aria-label="Reviews"
            >
              {caseItem.caseReviews.map((_, dotIndex) => (
                <button
                  type="button"
                  class:list={[
                    "caseReviewsSliderDot",
                    dotIndex === 0 && "is-active",
                  ]}
                  aria-label={`Go to review ${dotIndex + 1}`}
                  aria-current={dotIndex === 0 ? "true" : "false"}
                />
              ))}
            </div>
          )}
        </div>
      </section>
    )}
  </section>
  <div class="extraShots">
    <div class="extraShotsLeft">
      <span class="extraShotsLabel">Next Case:</span>
      <span class="extraShotsNextCase desktop-only">{caseItem.nextCase.title}</span>
      <span class="extraShotsNextCase mobile-only">{caseItem.nextCase.shortTitle}</span>
    </div>
    <span class="extraShotsPlus" aria-hidden="true">
      <span class="icon-arrow-right" aria-hidden="true"></span>
    </span>
    <a class="extraShotsLink" href={`/cases/${caseItem.nextCase.id}`}></a>
  </div>

  <script is:inline>
    (function () {
      function initSlider(root) {
        var viewport = root.querySelector(".caseImagesSliderViewport");
        var inner = root.querySelector(".caseImagesSliderInner");
        var slides = root.querySelectorAll(".caseImagesSliderSlide");
        var dots = root.querySelectorAll(".caseImagesSliderDot");
        var prev = root.querySelector(".caseImagesSliderNavPrev");
        var next = root.querySelector(".caseImagesSliderNavNext");
        if (!viewport || slides.length < 2) return;

        var index = 0;
        var scrollRaf = null;

        function updateDots() {
          for (var i = 0; i < dots.length; i++) {
            dots[i].classList.toggle("is-active", i === index);
            dots[i].setAttribute(
              "aria-current",
              i === index ? "true" : "false"
            );
          }
        }

        function updateAria() {
          for (var i = 0; i < slides.length; i++) {
            slides[i].setAttribute(
              "aria-hidden",
              i === index ? "false" : "true"
            );
          }
        }

        function goTo(i) {
          var n = slides.length;
          if (n === 0) return;
          var next = ((i % n) + n) % n;
          var wrapAround =
            (index === n - 1 && next === 0) ||
            (index === 0 && next === n - 1);
          index = next;
          var slide = slides[index];
          viewport.scrollTo({
            left: slide.offsetLeft,
            behavior: wrapAround ? "auto" : "smooth",
          });
          updateDots();
          updateAria();
        }

        function readIndexFromScroll() {
          var w = viewport.clientWidth;
          var x = viewport.scrollLeft + w / 2;
          var closest = 0;
          var best = Infinity;
          for (var i = 0; i < slides.length; i++) {
            var s = slides[i];
            var mid = s.offsetLeft + s.offsetWidth / 2;
            var d = Math.abs(mid - x);
            if (d < best) {
              best = d;
              closest = i;
            }
          }
          if (closest !== index) {
            index = closest;
            updateDots();
            updateAria();
          }
        }

        if (prev)
          prev.addEventListener("click", function () {
            goTo(index - 1);
          });
        if (next)
          next.addEventListener("click", function () {
            goTo(index + 1);
          });
        for (var d = 0; d < dots.length; d++) {
          (function (i) {
            dots[i].addEventListener("click", function () {
              goTo(i);
            });
          })(d);
        }

        function onViewportScroll() {
          if (scrollRaf !== null) return;
          scrollRaf = requestAnimationFrame(function () {
            scrollRaf = null;
            readIndexFromScroll();
          });
        }

        viewport.addEventListener("scroll", onViewportScroll, { passive: true });

        viewport.addEventListener("keydown", function (e) {
          if (e.key === "ArrowLeft") {
            e.preventDefault();
            goTo(index - 1);
          }
          if (e.key === "ArrowRight") {
            e.preventDefault();
            goTo(index + 1);
          }
        });

        /* Tap left/right half of viewport to prev/next (ignore if user dragged to scroll). */
        var tapTrack = null;
        var TAP_MOVE_PX = 14;
        viewport.addEventListener("pointerdown", function (e) {
          if (e.pointerType === "mouse" && e.button !== 0) return;
          tapTrack = {
            id: e.pointerId,
            x: e.clientX,
            y: e.clientY,
            cancelled: false,
          };
        });
        viewport.addEventListener("pointermove", function (e) {
          if (!tapTrack || tapTrack.id !== e.pointerId) return;
          if (
            Math.abs(e.clientX - tapTrack.x) > TAP_MOVE_PX ||
            Math.abs(e.clientY - tapTrack.y) > TAP_MOVE_PX
          ) {
            tapTrack.cancelled = true;
          }
        });
        function clearTap(e) {
          if (!tapTrack || tapTrack.id !== e.pointerId) return;
          var t = tapTrack;
          tapTrack = null;
          if (t.cancelled) return;
          var rect = viewport.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;
          if (x < 0 || x > rect.width || y < 0 || y > rect.height) return;
          if (x < rect.width / 2) goTo(index - 1);
          else goTo(index + 1);
        }
        viewport.addEventListener("pointerup", clearTap);
        viewport.addEventListener("pointercancel", function (e) {
          if (tapTrack && tapTrack.id === e.pointerId) tapTrack = null;
        });

        /* Hover arrow that matches left/right half of slider (mouse / pen only). */
        if (inner && prev && next) {
          function clearHalfHover() {
            root.classList.remove("caseImagesSlider--half-left");
            root.classList.remove("caseImagesSlider--half-right");
          }
          function updateHalfHover(clientX) {
            var rect = inner.getBoundingClientRect();
            var x = clientX - rect.left;
            if (x < rect.width * 0.5) {
              root.classList.add("caseImagesSlider--half-left");
              root.classList.remove("caseImagesSlider--half-right");
            } else {
              root.classList.remove("caseImagesSlider--half-left");
              root.classList.add("caseImagesSlider--half-right");
            }
          }
          inner.addEventListener("pointermove", function (e) {
            if (e.pointerType === "touch") return;
            updateHalfHover(e.clientX);
          });
          inner.addEventListener("pointerleave", clearHalfHover);
        }
      }

      function initReviewsSlider(root) {
        var viewport = root.querySelector(".caseReviewsSliderViewport");
        var inner = root.querySelector(".caseReviewsSliderInner");
        var slides = root.querySelectorAll(".caseReviewsSliderSlide");
        var dots = root.querySelectorAll(".caseReviewsSliderDot");
        var prev = root.querySelector(".caseReviewsSliderNavPrev");
        var next = root.querySelector(".caseReviewsSliderNavNext");
        if (!viewport || slides.length < 2) return;

        var index = 0;
        var scrollRaf = null;

        function updateDots() {
          for (var i = 0; i < dots.length; i++) {
            dots[i].classList.toggle("is-active", i === index);
            dots[i].setAttribute(
              "aria-current",
              i === index ? "true" : "false"
            );
          }
        }

        function updateAria() {
          for (var i = 0; i < slides.length; i++) {
            slides[i].setAttribute(
              "aria-hidden",
              i === index ? "false" : "true"
            );
          }
        }

        function goTo(i) {
          var n = slides.length;
          if (n === 0) return;
          var nextIdx = ((i % n) + n) % n;
          var wrapAround =
            (index === n - 1 && nextIdx === 0) ||
            (index === 0 && nextIdx === n - 1);
          index = nextIdx;
          var slide = slides[index];
          viewport.scrollTo({
            left: slide.offsetLeft,
            behavior: wrapAround ? "auto" : "smooth",
          });
          updateDots();
          updateAria();
        }

        function readIndexFromScroll() {
          var w = viewport.clientWidth;
          var x = viewport.scrollLeft + w / 2;
          var closest = 0;
          var best = Infinity;
          for (var i = 0; i < slides.length; i++) {
            var s = slides[i];
            var mid = s.offsetLeft + s.offsetWidth / 2;
            var d = Math.abs(mid - x);
            if (d < best) {
              best = d;
              closest = i;
            }
          }
          if (closest !== index) {
            index = closest;
            updateDots();
            updateAria();
          }
        }

        if (prev)
          prev.addEventListener("click", function () {
            goTo(index - 1);
          });
        if (next)
          next.addEventListener("click", function () {
            goTo(index + 1);
          });
        for (var d = 0; d < dots.length; d++) {
          (function (i) {
            dots[i].addEventListener("click", function () {
              goTo(i);
            });
          })(d);
        }

        function onReviewsViewportScroll() {
          if (scrollRaf !== null) return;
          scrollRaf = requestAnimationFrame(function () {
            scrollRaf = null;
            readIndexFromScroll();
          });
        }

        viewport.addEventListener("scroll", onReviewsViewportScroll, { passive: true });

        viewport.addEventListener("keydown", function (e) {
          if (e.key === "ArrowLeft") {
            e.preventDefault();
            goTo(index - 1);
          }
          if (e.key === "ArrowRight") {
            e.preventDefault();
            goTo(index + 1);
          }
        });

        /* Tap left/right half of viewport (same as case images slider). */
        var revTapTrack = null;
        var REV_TAP_MOVE_PX = 14;
        viewport.addEventListener("pointerdown", function (e) {
          if (e.pointerType === "mouse" && e.button !== 0) return;
          revTapTrack = {
            id: e.pointerId,
            x: e.clientX,
            y: e.clientY,
            cancelled: false,
          };
        });
        viewport.addEventListener("pointermove", function (e) {
          if (!revTapTrack || revTapTrack.id !== e.pointerId) return;
          if (
            Math.abs(e.clientX - revTapTrack.x) > REV_TAP_MOVE_PX ||
            Math.abs(e.clientY - revTapTrack.y) > REV_TAP_MOVE_PX
          ) {
            revTapTrack.cancelled = true;
          }
        });
        function clearRevTap(e) {
          if (!revTapTrack || revTapTrack.id !== e.pointerId) return;
          var t = revTapTrack;
          revTapTrack = null;
          if (t.cancelled) return;
          var rect = viewport.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;
          if (x < 0 || x > rect.width || y < 0 || y > rect.height) return;
          if (x < rect.width / 2) goTo(index - 1);
          else goTo(index + 1);
        }
        viewport.addEventListener("pointerup", clearRevTap);
        viewport.addEventListener("pointercancel", function (e) {
          if (revTapTrack && revTapTrack.id === e.pointerId) revTapTrack = null;
        });

        /* Hover arrow by left/right half (mouse / pen). */
        if (inner && prev && next) {
          function clearRevHalfHover() {
            root.classList.remove("caseReviewsSlider--half-left");
            root.classList.remove("caseReviewsSlider--half-right");
          }
          function updateRevHalfHover(clientX) {
            var rect = inner.getBoundingClientRect();
            var x = clientX - rect.left;
            if (x < rect.width * 0.5) {
              root.classList.add("caseReviewsSlider--half-left");
              root.classList.remove("caseReviewsSlider--half-right");
            } else {
              root.classList.remove("caseReviewsSlider--half-left");
              root.classList.add("caseReviewsSlider--half-right");
            }
          }
          inner.addEventListener("pointermove", function (e) {
            if (e.pointerType === "touch") return;
            updateRevHalfHover(e.clientX);
          });
          inner.addEventListener("pointerleave", clearRevHalfHover);
        }
      }

      function initManualVideo(panel) {
        var video = panel.querySelector(".caseVideo");
        var btn = panel.querySelector(".caseVideoPlay");
        if (!video || !btn) return;

        function hideOverlay() {
          panel.classList.add("is-overlay-hidden");
        }
        function showOverlay() {
          panel.classList.remove("is-overlay-hidden");
        }

        video.addEventListener("play", function () {
          hideOverlay();
          video.controls = true;
          btn.setAttribute("aria-hidden", "true");
        });
        video.addEventListener("ended", function () {
          showOverlay();
          video.controls = false;
          video.currentTime = 0;
          btn.setAttribute("aria-hidden", "false");
        });

        btn.addEventListener("click", function () {
          video.muted = false;
          if (video.ended) video.currentTime = 0;
          video.play().catch(function () {});
        });
      }

      document.querySelectorAll(".caseImagesSlider").forEach(initSlider);
      document.querySelectorAll(".caseReviewsSlider").forEach(initReviewsSlider);
      document.querySelectorAll(".caseVideoPanel--manualPlay").forEach(initManualVideo);
    })();
  </script>

  <style>
    .casePage {
      padding: 6.944vw 0 3.472vw;
    }

    .caseTop {
      margin: 0 auto 2.361vw;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6944vw;
      align-items: start;
    }

    .caseBrand {
      color: var(--color-primary);
      font-weight: 500;
      font-size: 1.3889vw;
      line-height: 1;
      margin: 0 0 1.042vw;
    }

    .caseTitle {
      margin: 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1.2;
      margin: 0 0 1.042vw;
    }

    .caseMeta {
      color: rgba(0, 0, 0, 0.35);
      display: flex;
      flex-wrap: wrap;
      gap: 0.764vw;
      font-size: 1.1111vw;
      line-height: 1.3889vw;
    }

    .caseRight {
      padding-top: 2.5vw;
    }

    .caseRight :global(p) {
      font-size: 1.1111vw;
      line-height: 1.3889vw;
      margin: 0 0 1.042vw;
    }

    .caseVideoPanel--manualPlay {
      position: relative;
    }

    .caseVideoPlay {
      position: absolute;
      inset: 0;
      z-index: 2;
      margin: 0;
      padding: 0;
      border: none;
      background: transparent;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease;
    }

    .caseVideoPanel--manualPlay.is-overlay-hidden .caseVideoPlay {
      opacity: 0;
