---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { homeCases } from "../../config/homeCases";

export function getStaticPaths() {
  return homeCases.map((c) => ({
    params: { slug: c.id },
  }));
}

const { slug } = Astro.params;
const slugStr = typeof slug === "string" ? slug : String(slug ?? "");
const caseItem = homeCases.find((c) => c.id === slugStr)!;

/** Vite imports `.mp4` as a string URL; images use `{ src }`. */
function videoUrl(video: string | { src: string }): string {
  return typeof video === "string" ? video : video.src;
}
---

<BaseLayout title={caseItem.brand}>
  <section class="casePage">
    <div class="caseTop">
      <div class="caseLeft">
        <p class="caseBrand">{caseItem.brand}</p>
        <h1 class="caseTitle">{caseItem.title}</h1>

        <div class="caseMeta">
          <span>{caseItem.meta.dateRange}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.location}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.stack}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.roles}</span>
        </div>
      </div>

      <div class="caseRight" set:html={caseItem.fullStoryText}></div>
    </div>

    {caseItem.paragraphs.map((p) => (
      <>
        {p.type === "video" && (
          <div class="caseVideoPanel">
            <video
              class="caseVideo"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
              src={videoUrl(p.video)}
            >
              Your browser does not support the video tag.
            </video>
          </div>
        )}
        {p.type === "image" && (
          <div class="caseImagePanel">
            <img
              class="caseImage"
              src={p.image.src}
              alt={p.imageAlt}
              loading="lazy"
            />
          </div>
        )}
        {p.type === "text" && (
          <div class="caseParagraph">
            {"textBeforeTitle" in p && p.textBeforeTitle && (
              <div class="caseParagraphText" set:html={p.textBeforeTitle}></div>
            )}
            {"title" in p && p.title && <h2 class="caseParagraphTitle">{p.title}</h2>}
            <div class="caseParagraphText" set:html={p.text}></div>
          </div>
        )}
      </>
    ))}

    {caseItem.caseReviews.length > 0 && (
      <section class="caseReviews" aria-label="Case reviews">
        {caseItem.caseReviews.map((review) => (
          <article class="caseReviewCard">
            <div class="caseReviewContent">
              <img
                class="caseReviewAvatar"
                src={review.avatar.src}
                alt={`${review.author} avatar`}
                loading="lazy"
              />
              <div class="caseReviewAuthor">{review.author}</div>
              <div class="caseReviewRole">{review.role}</div>
              <div class="caseReviewText" set:html={review.text}></div>
            </div>
          </article>
        ))}
      </section>
    )}
  </section>
  <div class="extraShots">
    <div class="extraShotsLeft">
      <span class="extraShotsLabel">Next Case:</span>
      <span class="extraShotsNextCase desktop-only">{caseItem.nextCase.title}</span>
      <span class="extraShotsNextCase mobile-only">{caseItem.nextCase.shortTitle}</span>
    </div>
    <span class="extraShotsPlus" aria-hidden="true">
      <span class="icon-arrow-right" aria-hidden="true"></span>
    </span>
    <a class="extraShotsLink" href={`/cases/${caseItem.nextCase.id}`}></a>
  </div>

  <style>
    .casePage {
      padding: 6.944vw 0 3.472vw;
    }

    .caseTop {
      margin: 0 auto 2.7778vw;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6944vw;
      align-items: start;
    }

    .caseBrand {
      color: var(--color-primary);
      font-weight: 500;
      font-size: 1.3889vw;
      line-height: 1;
      margin: 0 0 1.042vw;
    }

    .caseTitle {
      margin: 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1;
      margin: 0 0 1.042vw;
    }

    .caseMeta {
      color: rgba(0, 0, 0, 0.35);
      display: flex;
      flex-wrap: wrap;
      gap: 0.694vw;
      font-size: 1.1111vw;
      line-height: 1.3889vw;
    }

    .caseVideo {
      width: 100%;
      height: auto;
      display: block;
    }

    .caseImage {
      width: 100%;
      height: auto;
      display: block;
    }

    .caseRight :global(p) {
      font-size: 1.1111vw;
      line-height: 1.3889vw;
      margin: 0 0 1.042vw;
    }

    .caseVideoPanel {
      margin: 1.388vw 0;
    }

    .caseImagePanel {
      margin: 1.388vw 0;
    }

    .caseParagraph {
      margin: 3.472vw auto;
      max-width: 48.26vw;
    }

    .caseParagraphTitle {
      font-size: 1.3889vw;
      font-weight: 500;
      line-height: 1;
      margin: 3.472vw 0 1.042vw;
    }

    .caseParagraphText :global(p) {
      font-size: 1.1111vw;
      line-height: 1.3889vw;
      margin: 0 0 1.042vw;
    }
    .caseParagraphText :global(a) {
      color: var(--color-primary);
    }
    .caseParagraphText :global(a:hover) {
      color: var(--color-primary-hover);
      text-decoration: underline;
    }

    .caseBottom {
      margin-top: 2.5vw;
      text-align: center;
    }

    .caseBackLink {
      color: rgba(0, 0, 0, 0.4);
      text-decoration: none;
      font-weight: 500;
    }

    .caseBackLink:hover {
      color: var(--color-primary);
      text-decoration: underline;
    }

    .extraShots {
      display: flex;
      align-items: center;
      height: 5.5556vw;
      justify-content: space-between;
      border-bottom: 1px solid #d9d9d9;
      border-top: 1px solid #d9d9d9;
      padding: 2.0833vw 0;
      position: relative;
    }

    .extraShotsLeft {
      display: flex;
      align-items: center;
      gap: 0.6944vw;
    }
    .extraShotsLabel {
      color: var(--color-primary);
      font-size: 1.3889vw;
      line-height: 1;
    }
    .extraShotsNextCase {
      font-size: 1.3889vw;
      line-height: 1;
    }
    .extraShots:hover .extraShotsLabel,
    .extraShots:hover .extraShotsNextCase {
      color: var(--color-primary-hover);
    }
    .extraShots:hover .icon-arrow-right {
      background-color: var(--color-primary-hover);
    }
    .extraShotsLink {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
    }

    .extraShotsPlus {
      align-items: center;
      color: var(--color-primary);
      display: flex;
      height: 1.3889vw;
      width: 1.3889vw;
    }

    .caseReviewCard {
      border: 1px solid #d9d9d9;
      border-radius: 0.694vw;
      display: grid;
      align-items: center;
      gap: 1.3889vw;
      min-height: 45.486vw;
    }

    .caseReviewArrow {
      width: 3.472vw;
      height: 3.472vw;
      border: none;
      border-radius: 999px;
      background: transparent;
      color: var(--color-fg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
    }

    .caseReviewContent {
      text-align: center;
      max-width: 48.264vw;
      margin: 0 auto;
    }

    .caseReviewAvatar {
      width: 4.1667vw;
      height: 4.1667vw;
      border-radius: 999px;
      object-fit: cover;
      display: block;
      margin: 0 auto 0.694vw;
    }

    .caseReviewAuthor {
      font-size: 1.111vw;
      line-height: 1.25;
      margin: 0 0 0 0;
    }

    .caseReviewRole {
      color: rgba(0, 0, 0, 0.3);
      font-size: 1.111vw;
      line-height: 1.25;
      margin: 0 0 1.042vw;
    }

    .caseReviewText {
      font-size: 1.3889vw;
      line-height: 1.25;
    }
    .caseReviewText :global(p) {
      font-size: 1.3889vw;
      line-height: 1.25;
      margin: 0 0 1.3889vw;
    }

    @media (min-width: 1440px) {
      .casePage {
        padding: 100px 0 50px;
      }

      .caseTop {
        margin-bottom: 40px;
        gap: 10px;
      }

      .caseBrand {
        font-size: 20px;
        margin-bottom: 15px;
      }

      .caseTitle {
        font-size: 50px;
        margin-bottom: 15px;
      }

      .caseMeta {
        font-size: 16px;
        line-height: 20px;
        gap: 10px;
      }

      .caseRight :global(p) {
        font-size: 16px;
        line-height: 20px;
        margin-bottom: 15px;
      }

      .caseImagePanel {
        margin: 20px 0;
      }

      .caseParagraph {
        margin: 50px auto;
        max-width: 695px;
      }

      .caseParagraphTitle {
        font-size: 20px;
        margin: 50px 0 15px;
      }

      .caseParagraphText :global(p) {
        font-size: 16px;
        line-height: 20px;
        margin-bottom: 15px;
      }

      .extraShots {
        height: 80px;
        padding: 30px 0;
      }

      .extraShotsLeft {
        gap: 10px;
      }

      .extraShotsLabel,
      .extraShotsNextCase {
        font-size: 20px;
      }

      .extraShotsPlus {
        width: 20px;
        height: 20px;
      }

      .caseReviewCard {
        border-radius: 10px;
        gap: 20px;
        min-height: 655px;
      }

      .caseReviewContent {
        max-width: 695px;
      }

      .caseReviewAvatar {
        width: 60px;
        height: 60px;
        margin-bottom: 10px;
      }

      .caseReviewAuthor {
        font-size: 16px;
      }

      .caseReviewRole {
        font-size: 16px;
        margin-bottom: 15px;
      }

      .caseReviewText,
      .caseReviewText :global(p) {
        font-size: 20px;
        margin-bottom: 20px;
      }
    }

    @media (max-width: 600px) {
      .caseTop {
        grid-template-columns: 1fr;
        gap: 8vw;
      }

      .caseBrand {
        font-size: 5.333vw;
        margin-bottom: 4vw;
      }
      .caseTitle {
        font-size: 12vw;
        margin: 0 0 4vw;
      }
      .caseMeta {
        font-size: 4vw;
        line-height: 1.33;
        gap: 1.333vw;
      }
      .caseRight :global(p) {
        font-size: 4vw;
        line-height: 1.25;
        margin: 0 0 4vw;
      }

      .caseParagraph {
        margin: 8vw auto;
        max-width: 100%;
      }
      .caseParagraphTitle {
        font-size: 4.8vw;
        line-height: 5.333vw;
        margin: 8vw 0 4vw;
      }
      .caseParagraphText :global(p) {
        font-size: 4vw;
        line-height: 1.33;
        margin: 0 0 4vw;
      }
      .caseImagePanel {
        margin: 5.333vw 0;
      }

      .extraShots {
        height: 18.6667vw;
        padding: 6.6667vw 0;
      }
      .extraShotsLabel {
        font-size: 4.8vw;
        line-height: 5.333vw;
      }
      .extraShotsNextCase {
        font-size: 4.8vw;
        line-height: 5.333vw;
      }
      .extraShotsLink {
      }
      .extraShotsPlus {
        width: 5.3vw;
        height: 5.3vw;
      }

      .caseReviewCard {
        border-radius: 2.667vw;
        min-height: 133.33vw;
        padding: 0 3.7vw;
      }
      .caseReviewContent {;
        max-width: 100%;
      }
      .caseReviewAvatar {
        width: 16vw;
        height: 16vw;
        margin: 0 auto 2.667vw;
      }
      .caseReviewAuthor {
        font-size: 4.2667vw;
        line-height: 1.25;
      }
      .caseReviewRole {
        font-size: 4.2667vw;
        line-height: 1.25;
        margin: 0 0 4vw;
      }
      .caseReviewText {
        font-size: 4vw;
        line-height: 1.25;
      }
      .caseReviewText :global(p) {
        font-size: 4vw;
        line-height: 1.25;
        margin: 0 0 4vw;
      }
    }
  </style>
</BaseLayout>

