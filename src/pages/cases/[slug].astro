---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { homeCases } from "../../config/homeCases";

export function getStaticPaths() {
  return homeCases.map((c) => ({
    params: { slug: c.id },
  }));
}

const { slug } = Astro.params;
const slugStr = typeof slug === "string" ? slug : String(slug ?? "");
const caseItem = homeCases.find((c) => c.id === slugStr)!;

/** Vite imports `.mp4` as a string URL; images use `{ src }`. */
function videoUrl(video: string | { src: string }): string {
  return typeof video === "string" ? video : video.src;
}
---

<BaseLayout title={caseItem.brand}>
  <section class="casePage">
    <div class="caseTop">
      <div class="caseLeft">
        <p class="caseBrand">{caseItem.brand}</p>
        <h1 class="caseTitle">{caseItem.title}</h1>

        <div class="caseMeta">
          <span>{caseItem.meta.dateRange}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.location}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.stack}</span>
          <span class="sep">/</span>
          <span>{caseItem.meta.roles}</span>
        </div>
      </div>

      <div class="caseRight" set:html={caseItem.fullStoryText}></div>
    </div>

    {caseItem.paragraphs.map((p) => (
      <>
        {p.type === "video" && (
          <div class="caseVideoPanel">
            <video
              class="caseVideo"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
              src={videoUrl(p.video)}
            >
              Your browser does not support the video tag.
            </video>
          </div>
        )}
        {p.type === "image" && (
          <div class="caseImagePanel">
            <img
              class="caseImage"
              src={p.image.src}
              alt={p.imageAlt}
              loading="lazy"
            />
          </div>
        )}
        {p.type === "half" && (
          <div class="caseHalfPanel">
            <div
              class="caseHalfGrid"
              role="group"
              aria-label="Split layout: UI and media"
            >
              {p.images.map((it) => (
                it.image ? (
                  <img
                    class="caseHalfImg"
                    src={it.image.src}
                    alt={it.imageAlt}
                    loading="lazy"
                  />
                ) : (
                  <video
                    class="caseHalfVideo"
                    autoplay
                    loop
                    muted
                    playsinline
                    preload="auto"
                    src={videoUrl(it.video)}
                  >
                    Your browser does not support the video tag.
                  </video>
                )
              ))}
            </div>
          </div>
        )}
        {p.type === "images" && (
          <div class="caseImagesPanel">
            <div
              class="caseImagesSlider"
              role="region"
              aria-roledescription="carousel"
              aria-label="Case image gallery"
            >
              <div class="caseImagesSliderInner">
                <div
                  class:list={[
                    "caseImagesSliderViewport",
                    p.images.length > 1 && "caseImagesSliderViewport--seek",
                  ]}
                  tabindex={p.images.length > 1 ? 0 : undefined}
                >
                  <div class="caseImagesSliderTrack">
                    {p.images.map((image, slideIndex) => (
                      image.video ? (
                        <figure
                          class="caseImagesSliderSlide"
                          aria-hidden={slideIndex === 0 ? "false" : "true"}
                        >
                          <video
                            class="caseVideo caseImagesSliderImg"
                            autoplay
                            loop
                            muted
                            playsinline
                            preload="auto"
                            src={videoUrl(image.video)}
                          >
                            Your browser does not support the video tag.
                          </video>
                        </figure>
                      ) : (
                        <figure
                          class="caseImagesSliderSlide"
                          aria-hidden={slideIndex === 0 ? "false" : "true"}
                        >
                          <img
                            class="caseImage caseImagesSliderImg"
                            src={image.image.src}
                            alt={image.imageAlt}
                            loading={slideIndex === 0 ? "eager" : "lazy"}
                            draggable="false"
                          />
                        </figure>
                      )
                    ))}
                  </div>
                </div>
                {p.images.length > 1 && (
                  <>
                    <button
                      type="button"
                      class="caseImagesSliderNav caseImagesSliderNavPrev"
                      aria-label="Previous slide"
                    >
                      <span class="icon-arrow-right" aria-hidden="true"></span>
                    </button>
                    <button
                      type="button"
                      class="caseImagesSliderNav caseImagesSliderNavNext"
                      aria-label="Next slide"
                    >
                      <span class="icon-arrow-right" aria-hidden="true"></span>
                    </button>
                  </>
                )}
              </div>
              {p.images.length > 1 && (
                <div
                  class="caseImagesSliderDots mobile-only"
                  role="tablist"
                  aria-label="Slides"
                >
                  {p.images.map((_, dotIndex) => (
                    <button
                      type="button"
                      class:list={[
                        "caseImagesSliderDot",
                        dotIndex === 0 && "is-active",
                      ]}
                      aria-label={`Go to slide ${dotIndex + 1}`}
                      aria-current={dotIndex === 0 ? "true" : "false"}
                    />
                  ))}
                </div>
              )}
            </div>
          </div>
        )}
        {p.type === "text" && (
          <div class="caseParagraph">
            {"textBeforeTitle" in p && p.textBeforeTitle && (
              <div class="caseParagraphText" set:html={p.textBeforeTitle}></div>
            )}
            {"title" in p && p.title && <h2 class="caseParagraphTitle">{p.title}</h2>}
            <div class="caseParagraphText" set:html={p.text}></div>
          </div>
        )}
      </>
    ))}

    {caseItem.caseReviews.length > 0 && (
      <section class="caseReviews" aria-label="Case reviews">
        <div
          class="caseReviewsSlider"
          role="region"
          aria-roledescription="carousel"
          aria-label="Case reviews"
        >
          <div class="caseReviewsSliderInner">
            <div
              class="caseReviewsSliderViewport"
              tabindex={caseItem.caseReviews.length > 1 ? 0 : undefined}
            >
              <div class="caseReviewsSliderTrack">
                {caseItem.caseReviews.map((review, reviewIndex) => (
                  <article
                    class="caseReviewCard caseReviewsSliderSlide"
                    aria-hidden={reviewIndex === 0 ? "false" : "true"}
                  >
                    <div class="caseReviewContent">
                      <img
                        class="caseReviewAvatar"
                        src={review.avatar.src}
                        alt={`${review.author} avatar`}
                        loading={reviewIndex === 0 ? "eager" : "lazy"}
                      />
                      <div class="caseReviewAuthor">{review.author}</div>
                      <div class="caseReviewRole">{review.role}</div>
                      <div class="caseReviewText" set:html={review.text}></div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            {caseItem.caseReviews.length > 1 && (
              <>
                <button
                  type="button"
                  class="caseReviewsSliderNav caseReviewsSliderNavPrev"
                  aria-label="Previous review"
                >
                  <span class="icon-arrow-right" aria-hidden="true"></span>
                </button>
                <button
                  type="button"
                  class="caseReviewsSliderNav caseReviewsSliderNavNext"
                  aria-label="Next review"
                >
                  <span class="icon-arrow-right" aria-hidden="true"></span>
                </button>
              </>
            )}
          </div>
          {caseItem.caseReviews.length > 1 && (
            <div
              class="caseReviewsSliderDots"
              role="tablist"
              aria-label="Reviews"
            >
              {caseItem.caseReviews.map((_, dotIndex) => (
                <button
                  type="button"
                  class:list={[
                    "caseReviewsSliderDot",
                    dotIndex === 0 && "is-active",
                  ]}
                  aria-label={`Go to review ${dotIndex + 1}`}
                  aria-current={dotIndex === 0 ? "true" : "false"}
                />
              ))}
            </div>
          )}
        </div>
      </section>
    )}
  </section>
  <div class="extraShots">
    <div class="extraShotsLeft">
      <span class="extraShotsLabel">Next Case:</span>
      <span class="extraShotsNextCase desktop-only">{caseItem.nextCase.title}</span>
      <span class="extraShotsNextCase mobile-only">{caseItem.nextCase.shortTitle}</span>
    </div>
    <span class="extraShotsPlus" aria-hidden="true">
      <span class="icon-arrow-right" aria-hidden="true"></span>
    </span>
    <a class="extraShotsLink" href={`/cases/${caseItem.nextCase.id}`}></a>
  </div>

  <script is:inline>
    (function () {
      function initSlider(root) {
        var viewport = root.querySelector(".caseImagesSliderViewport");
        var inner = root.querySelector(".caseImagesSliderInner");
        var slides = root.querySelectorAll(".caseImagesSliderSlide");
        var dots = root.querySelectorAll(".caseImagesSliderDot");
        var prev = root.querySelector(".caseImagesSliderNavPrev");
        var next = root.querySelector(".caseImagesSliderNavNext");
        if (!viewport || slides.length < 2) return;

        var index = 0;
        var scrollEndTimer;

        function updateDots() {
          for (var i = 0; i < dots.length; i++) {
            dots[i].classList.toggle("is-active", i === index);
            dots[i].setAttribute(
              "aria-current",
              i === index ? "true" : "false"
            );
          }
        }

        function updateAria() {
          for (var i = 0; i < slides.length; i++) {
            slides[i].setAttribute(
              "aria-hidden",
              i === index ? "false" : "true"
            );
          }
        }

        function goTo(i) {
          var n = slides.length;
          if (n === 0) return;
          var next = ((i % n) + n) % n;
          var wrapAround =
            (index === n - 1 && next === 0) ||
            (index === 0 && next === n - 1);
          index = next;
          var slide = slides[index];
          viewport.scrollTo({
            left: slide.offsetLeft,
            behavior: wrapAround ? "auto" : "smooth",
          });
          updateDots();
          updateAria();
        }

        function readIndexFromScroll() {
          var w = viewport.clientWidth;
          var x = viewport.scrollLeft + w / 2;
          var closest = 0;
          var best = Infinity;
          for (var i = 0; i < slides.length; i++) {
            var s = slides[i];
            var mid = s.offsetLeft + s.offsetWidth / 2;
            var d = Math.abs(mid - x);
            if (d < best) {
              best = d;
              closest = i;
            }
          }
          if (closest !== index) {
            index = closest;
            updateDots();
            updateAria();
          }
        }

        if (prev)
          prev.addEventListener("click", function () {
            goTo(index - 1);
          });
        if (next)
          next.addEventListener("click", function () {
            goTo(index + 1);
          });
        for (var d = 0; d < dots.length; d++) {
          (function (i) {
            dots[i].addEventListener("click", function () {
              goTo(i);
            });
          })(d);
        }

        viewport.addEventListener(
          "scroll",
          function () {
            clearTimeout(scrollEndTimer);
            scrollEndTimer = setTimeout(readIndexFromScroll, 80);
          },
          { passive: true }
        );

        viewport.addEventListener("keydown", function (e) {
          if (e.key === "ArrowLeft") {
            e.preventDefault();
            goTo(index - 1);
          }
          if (e.key === "ArrowRight") {
            e.preventDefault();
            goTo(index + 1);
          }
        });

        /* Tap left/right half of viewport to prev/next (ignore if user dragged to scroll). */
        var tapTrack = null;
        var TAP_MOVE_PX = 14;
        viewport.addEventListener("pointerdown", function (e) {
          if (e.pointerType === "mouse" && e.button !== 0) return;
          tapTrack = {
            id: e.pointerId,
            x: e.clientX,
            y: e.clientY,
            cancelled: false,
          };
        });
        viewport.addEventListener("pointermove", function (e) {
          if (!tapTrack || tapTrack.id !== e.pointerId) return;
          if (
            Math.abs(e.clientX - tapTrack.x) > TAP_MOVE_PX ||
            Math.abs(e.clientY - tapTrack.y) > TAP_MOVE_PX
          ) {
            tapTrack.cancelled = true;
          }
        });
        function clearTap(e) {
          if (!tapTrack || tapTrack.id !== e.pointerId) return;
          var t = tapTrack;
          tapTrack = null;
          if (t.cancelled) return;
          var rect = viewport.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;
          if (x < 0 || x > rect.width || y < 0 || y > rect.height) return;
          if (x < rect.width / 2) goTo(index - 1);
          else goTo(index + 1);
        }
        viewport.addEventListener("pointerup", clearTap);
        viewport.addEventListener("pointercancel", function (e) {
          if (tapTrack && tapTrack.id === e.pointerId) tapTrack = null;
        });

        /* Hover arrow that matches left/right half of slider (mouse / pen only). */
        if (inner && prev && next) {
          function clearHalfHover() {
            root.classList.remove("caseImagesSlider--half-left");
            root.classList.remove("caseImagesSlider--half-right");
          }
          function updateHalfHover(clientX) {
            var rect = inner.getBoundingClientRect();
            var x = clientX - rect.left;
            if (x < rect.width * 0.5) {
              root.classList.add("caseImagesSlider--half-left");
              root.classList.remove("caseImagesSlider--half-right");
            } else {
              root.classList.remove("caseImagesSlider--half-left");
              root.classList.add("caseImagesSlider--half-right");
            }
          }
          inner.addEventListener("pointermove", function (e) {
            if (e.pointerType === "touch") return;
            updateHalfHover(e.clientX);
          });
          inner.addEventListener("pointerleave", clearHalfHover);
        }
      }

      function initReviewsSlider(root) {
        var viewport = root.querySelector(".caseReviewsSliderViewport");
        var slides = root.querySelectorAll(".caseReviewsSliderSlide");
        var dots = root.querySelectorAll(".caseReviewsSliderDot");
        var prev = root.querySelector(".caseReviewsSliderNavPrev");
        var next = root.querySelector(".caseReviewsSliderNavNext");
        if (!viewport || slides.length < 2) return;

        var index = 0;
        var scrollEndTimer;

        function updateDots() {
          for (var i = 0; i < dots.length; i++) {
            dots[i].classList.toggle("is-active", i === index);
            dots[i].setAttribute(
              "aria-current",
              i === index ? "true" : "false"
            );
          }
        }

        function updateAria() {
          for (var i = 0; i < slides.length; i++) {
            slides[i].setAttribute(
              "aria-hidden",
              i === index ? "false" : "true"
            );
          }
        }

        function goTo(i) {
          var n = slides.length;
          if (n === 0) return;
          var nextIdx = ((i % n) + n) % n;
          var wrapAround =
            (index === n - 1 && nextIdx === 0) ||
            (index === 0 && nextIdx === n - 1);
          index = nextIdx;
          var slide = slides[index];
          viewport.scrollTo({
            left: slide.offsetLeft,
            behavior: wrapAround ? "auto" : "smooth",
          });
          updateDots();
          updateAria();
        }

        function readIndexFromScroll() {
          var w = viewport.clientWidth;
          var x = viewport.scrollLeft + w / 2;
          var closest = 0;
          var best = Infinity;
          for (var i = 0; i < slides.length; i++) {
            var s = slides[i];
            var mid = s.offsetLeft + s.offsetWidth / 2;
            var d = Math.abs(mid - x);
            if (d < best) {
              best = d;
              closest = i;
            }
          }
          if (closest !== index) {
            index = closest;
            updateDots();
            updateAria();
          }
        }

        if (prev)
          prev.addEventListener("click", function () {
            goTo(index - 1);
          });
        if (next)
          next.addEventListener("click", function () {
            goTo(index + 1);
          });
        for (var d = 0; d < dots.length; d++) {
          (function (i) {
            dots[i].addEventListener("click", function () {
              goTo(i);
            });
          })(d);
        }

        viewport.addEventListener(
          "scroll",
          function () {
            clearTimeout(scrollEndTimer);
            scrollEndTimer = setTimeout(readIndexFromScroll, 80);
          },
          { passive: true }
        );

        viewport.addEventListener("keydown", function (e) {
          if (e.key === "ArrowLeft") {
            e.preventDefault();
            goTo(index - 1);
          }
          if (e.key === "ArrowRight") {
            e.preventDefault();
            goTo(index + 1);
          }
        });
      }

      document.querySelectorAll(".caseImagesSlider").forEach(initSlider);
      document.querySelectorAll(".caseReviewsSlider").forEach(initReviewsSlider);
    })();
  </script>

  <style>
    .casePage {
      padding: 6.944vw 0 3.472vw;
    }

    .caseTop {
      margin: 0 auto 2.7778vw;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6944vw;
      align-items: start;
    }

    .caseBrand {
      color: var(--color-primary);
      font-weight: 500;
      font-size: 1.3889vw;
      line-height: 1;
      margin: 0 0 1.042vw;
    }

    .caseTitle {
      margin: 0;
      font-weight: 500;
      font-size: 3.472vw;
      letter-spacing: -0.02em;
      line-height: 1;
      margin: 0 0 1.042vw;
    }

    .caseMeta {
      color: rgba(0, 0, 0, 0.35);
      display: flex;
      flex-wrap: wrap;
      gap: 0.694vw;
      font-size: 1.1111vw;
      line-height: 1.3889vw;
    }

    .caseVideo {
      width: 100%;
      height: auto;
      display: block;
    }

    .caseImage {
      width: 100%;
      height: auto;
      display: block;
    }

    .caseRight :global(p) {
      font-size: 1.1111vw;
      line-height: 1.3889vw;
      margin: 0 0 1.042vw;
    }

    .caseVideoPanel {
      margin: 1.388vw 0;
    }

    .caseImagePanel {
      margin: 1.388vw 0;
    }

    .caseHalfPanel {
      margin: 1.388vw 0;
    }

    .caseHalfGrid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.042vw;
      align-items: stretch;
      overflow: hidden;
    }

    .caseHalfImg {
      border-radius: 0.694vw;
      display: block;
      width: 100%;
      height: auto;
    }

    /* Show right half of the video (full-bleed mockup), like the reference */
    .caseHalfVideo {
      border-radius: 0.694vw;
      display: block;
      width: 100%;
      max-width: none;
      height: 100%;
      object-fit: cover;
      object-position: center;
      margin-left: 0;
    }

    .caseImagesPanel {
      margin: 1.388vw 0;
    }

    .caseImagesSlider {
      display: flex;
      flex-direction: column;
      gap: 1.042vw;
      position: relative;
    }

    .caseImagesSliderInner {
      position: relative;
    }

    .caseImagesSliderViewport {
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      /* pan-x alone blocks vertical page scroll on touch; allow both axes */
      touch-action: pan-x pan-y;
      border-radius: 0.694vw;
      scrollbar-width: none;
    }

    .caseImagesSliderViewport::-webkit-scrollbar {
      display: none;
    }

    .caseImagesSliderViewport--seek {
      cursor: pointer;
    }

    .caseImagesSliderTrack {
      display: flex;
    }

    .caseImagesSliderSlide {
      flex: 0 0 100%;
      min-width: 100%;
      scroll-snap-align: start;
      margin: 0;
    }

    .caseImagesSliderImg {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 0.694vw;
      user-select: none;
    }

    .caseImagesSliderNav {
      position: absolute;
      top: 50%;
      z-index: 2;
      width: 3.472vw;
      height: 3.472vw;
      margin: 0;
      padding: 0;
      border: none;
      border-radius: 999px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      color: var(--color-primary);
      cursor: pointer;
      transform: translateY(-50%);
      transition: border-color 0.15s ease, color 0.15s ease;
    }

    .caseImagesSliderNav:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }

    .caseImagesSliderNavPrev {
      left: 1.042vw;
    }

    .caseImagesSliderNavNext {
      right: 1.042vw;
    }

    .caseImagesSliderNavPrev .icon-arrow-right {
      transform: rotate(180deg);
    }

    .caseImagesSliderNavPrev .icon-arrow-right,
    .caseImagesSliderNavNext .icon-arrow-right {
      color: var(--color-fg);
    }
    .caseImagesSliderNav:hover,
    .caseImagesSlider--half-left .caseImagesSliderNavPrev,
    .caseImagesSlider--half-right .caseImagesSliderNavNext {
      border-color: var(--color-primary);
      color: var(--color-primary-hover);
      background-color: var(--color-primary);
    }
    .caseImagesSliderNavPrev:hover .icon-arrow-right,
    .caseImagesSliderNavNext:hover .icon-arrow-right,
    .caseImagesSlider--half-left .caseImagesSliderNavPrev .icon-arrow-right,
    .caseImagesSlider--half-right .caseImagesSliderNavNext .icon-arrow-right {
      color: var(--color-bg);
    }

    .caseImagesSliderDots {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.694vw;
    }
    .caseImagesSliderDots.mobile-only {
      display: none;
    }

    .caseImagesSliderDot {
      width: 1.6vw;
      height: 1.6vw;
      padding: 0;
      border: none;
      border-radius: 999px;
      background: #d9d9d9;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease;
    }

    .caseImagesSliderDot:hover {
      background: rgba(255, 64, 1, 0.45);
    }

    .caseImagesSliderDot.is-active {
      background: var(--color-primary);
    }

    .caseImagesSliderDot:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
    }

    .caseImage, .caseVideo {
      border-radius: 0.694vw;
    }

    .caseParagraph {
      margin: 3.472vw auto;
      max-width: 48.26vw;
    }

    .caseParagraphTitle {
      font-size: 1.3889vw;
      font-weight: 500;
      line-height: 1;
      margin: 3.472vw 0 1.042vw;
    }

    .caseParagraphText :global(p) {
      font-size: 1.1111vw;
      line-height: 1.3889vw;
      margin: 0 0 1.042vw;
    }
    .caseParagraphText :global(a) {
      color: var(--color-primary);
    }
    .caseParagraphText :global(a:hover) {
      color: var(--color-primary-hover);
      text-decoration: underline;
    }

    .caseBottom {
      margin-top: 2.5vw;
      text-align: center;
    }

    .caseBackLink {
      color: rgba(0, 0, 0, 0.4);
      text-decoration: none;
      font-weight: 500;
    }

    .caseBackLink:hover {
      color: var(--color-primary);
      text-decoration: underline;
    }

    .extraShots {
      display: flex;
      align-items: center;
      height: 5.5556vw;
      justify-content: space-between;
      border-bottom: 1px solid #d9d9d9;
      border-top: 1px solid #d9d9d9;
      padding: 2.0833vw 0;
      position: relative;
    }

    .extraShotsLeft {
      display: flex;
      align-items: center;
      gap: 0.6944vw;
    }
    .extraShotsLabel {
      color: var(--color-primary);
      font-size: 1.3889vw;
      line-height: 1;
    }
    .extraShotsNextCase {
      font-size: 1.3889vw;
      line-height: 1;
